{
  "installCommand": "cd ../.. && corepack enable && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm turbo build --filter=@bigmuddy/web",
  "crons": [
    {
      "path": "/api/cron/scan-asana",
      "schedule": "17 * * * *"
    },
    {
      "path": "/api/cron/process-enrichment-queue",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/sync-google",
      "schedule": "23 3 * * *"
    }
  ]
}
