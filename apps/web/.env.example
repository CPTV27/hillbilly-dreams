# Copy to `.env.local` for local dev. Production: Vercel + Bitwarden as source of truth.

# Big Muddy Radio — Icecast stream URL (player + /api/radio/now-playing base). Mac mini LAN default.
NEXT_PUBLIC_ICECAST_URL=http://192.168.4.37:8010/stream

# Postiz (social auto-publish — GitHub #33). Generate API key from Postiz admin (e.g. Mac mini :4007).
POSTIZ_URL=http://localhost:4007
POSTIZ_API_KEY=

# NextAuth, database, etc. — see Bitwarden / Vercel project settings; do not commit secrets.
