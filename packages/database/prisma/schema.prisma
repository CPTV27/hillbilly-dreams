// packages/database/prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Use connection pooling URL for serverless (Next.js API routes, Firebase Functions)
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// MAGAZINE
// ─────────────────────────────────────────────────────────────

model Article {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  category    String    // city-guide | feature | photo-essay | interview | food-drink | music
  city        String?   // memphis | clarksdale | natchez | new-orleans | vicksburg | etc.
  author      String    @default("Big Muddy Magazine")
  status      String    @default("draft")     // draft | review | published
  excerpt     String?
  body        String?   @db.Text
  heroImage   String?   // Cloudflare R2 URL
  readTime    String?   // e.g. "6 min read"
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // ── S2PX Bridge Provenance ──
  sourceSystem    String?   // "s2px" | null (manual)
  sourceProjectId String?   // S2PX UPID e.g. "S2P-042-2025"
  sourcePayload   String?   @db.Text  // Sanitized JSON audit trail
  sourceSyncedAt  DateTime?

  // ── Deep South Directory Link ──
  clientId    Int?
  client      Client?   @relation(fields: [clientId], references: [id])

  @@index([status, publishedAt])
  @@index([category])
  @@index([city])
  @@index([clientId])
  @@index([sourceSystem, sourceProjectId])
}

// ─────────────────────────────────────────────────────────────
// RADIO
// ─────────────────────────────────────────────────────────────

model Playlist {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  trackCount  Int      @default(0)
  spotifyUrl  String?  // spotify:playlist:xxx or https://open.spotify.com/playlist/xxx
  coverImage  String?  // Cloudflare R2 URL
  status      String   @default("active")  // active | archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model Event {
  id          Int      @id @default(autoincrement())
  name        String
  date        DateTime
  time        String?              // e.g. "7:00 PM CT" — stored separately for display flexibility
  artist      String?
  description String?
  price       String?              // e.g. "$25" or "Free" — string to allow flexibility
  capacity    Int      @default(50)
  status      String   @default("upcoming")  // upcoming | sold-out | cancelled | completed
  stream      Boolean  @default(false)       // whether this event will be livestreamed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date, status])
}

// ─────────────────────────────────────────────────────────────
// NEWSLETTER
// ─────────────────────────────────────────────────────────────

model NewsletterIssue {
  id          Int      @id @default(autoincrement())
  issueNumber Int      @unique
  subject     String
  storyTitle  String?
  storyBody   String?  @db.Text
  playlist    String?  // Playlist name or Spotify URL
  reason      String?  // "Why You Should Go" section
  quickHits   String?  @db.Text  // Comma-separated or JSON array of bullets
  status      String   @default("draft")  // draft | scheduled | sent
  sendDate    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, sendDate])
}

// ─────────────────────────────────────────────────────────────
// CRM / CONTACTS
// ─────────────────────────────────────────────────────────────

model Contact {
  id           Int       @id @default(autoincrement())
  name         String
  role         String?
  organization String?
  email        String?
  phone        String?
  category     String?   // artist | vendor | media | partner | guest | team
  notes        String?   @db.Text
  lastContact  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([category])
  @@index([email])
}

// ─────────────────────────────────────────────────────────────
// DASHBOARD METRICS
// ─────────────────────────────────────────────────────────────

model Metric {
  id        Int      @id @default(autoincrement())
  key       String   @unique  // e.g. "newsletter_subscribers", "inn_occupancy_rate", "spotify_followers"
  value     Float
  target    Float?
  label     String?           // Display label: "Newsletter Subscribers"
  unit      String?           // "subscribers", "%", "followers", etc.
  source    String?           // "beehiiv" | "cloudbeds" | "spotify" | "manual"
  updatedAt DateTime @updatedAt

  @@index([key])
}

// ─────────────────────────────────────────────────────────────
// BRIDGE CLIENTS (Multi-Tenant Content-as-a-Service)
// ─────────────────────────────────────────────────────────────

model BridgeClient {
  id          Int      @id @default(autoincrement())
  name        String                    // "Scan2Plan", "FutureClient_X"
  apiKey      String   @unique          // Public identifier (cuid)
  apiSecret   String                    // HMAC-SHA256 secret (64-char hex, hashed at rest)
  status      String   @default("active") // active | suspended
  allowedCategories String[]            // Which article categories this client can create
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastSyncAt  DateTime?

  @@index([apiKey])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// SOCIAL MEDIA
// ─────────────────────────────────────────────────────────────

model SocialAccount {
  id          Int      @id @default(autoincrement())
  platform    String   // twitter | tiktok | instagram | threads | bluesky | linkedin
  handle      String   // @outsiderecon, @bigmuddymedia, etc.
  brand       String   @default("bigmuddy") // bigmuddy | radio | magazine | touring | economics
  status      String   @default("active")   // active | paused | disconnected
  notes       String?
  clientId    Int?
  client      Client?  @relation(fields: [clientId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       SocialPost[]

  @@unique([platform, handle])
  @@index([brand])
  @@index([status])
}

model SocialPost {
  id          Int       @id @default(autoincrement())
  accountId   Int
  account     SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  content     String    @db.Text           // Post body / caption
  mediaUrls   String[]                     // GCS image/video URLs
  postUrl     String?                      // URL after publishing (paste back)
  status      String    @default("draft")  // draft | ready | published | failed
  scheduledAt DateTime?                    // When to publish (null = no schedule)
  publishedAt DateTime?                    // When actually published
  sourceType  String?                      // article | newsletter | event | economics | manual
  sourceId    String?                      // Reference to source content ID
  tags        String[]                     // hashtags, topics
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([accountId, status])
  @@index([status, scheduledAt])
  @@index([sourceType, sourceId])
}

// ─────────────────────────────────────────────────────────────
// CLIENT MANAGEMENT (Media-as-a-Service)
// ─────────────────────────────────────────────────────────────

model Client {
  id               Int       @id @default(autoincrement())
  name             String
  slug             String    @unique
  tier             String    @default("front-porch") // front-porch | route | river-room | blues-room
  businessType     String    // restaurant | venue | hotel | shop | tour | service | other
  city             String
  state            String    @default("MS")
  address          String?
  phone            String?
  email            String?
  website          String?
  description      String?   @db.Text
  voiceProfile     Json?     // AI-generated brand voice document
  platforms        String[]  // which social platforms they're on
  gbpPlaceId       String?   // Google Business Profile place ID
  gbpUrl           String?   // Google Maps URL
  stripeCustomerId String?
  logoUrl          String?
  heroImageUrl     String?
  stripeConnectId  String?   // Stripe Connect account ID (acct_xxx)
  connectStatus    String?   // "pending" | "active" | "restricted" | "disabled"
  contactName      String?   // Primary contact person
  contactEmail     String?
  contactPhone     String?
  notes            String?   @db.Text
  status           String    @default("onboarding") // onboarding | active | paused | churned
  onboardedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts         SocialAccount[]
  articles         Article[]
  reviews          Review[]
  calendars        ContentCalendar[]
  reports          Report[]
  invoices         Invoice[]
  integrations     ClientIntegration[]

  @@index([city])
  @@index([tier, status])
  @@index([status])
}

model Review {
  id             Int       @id @default(autoincrement())
  clientId       Int
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform       String    // google | yelp | tripadvisor | facebook
  externalId     String    @unique
  author         String
  rating         Int       // 1-5
  text           String?   @db.Text
  response       String?   @db.Text   // Our drafted response
  responseStatus String    @default("pending") // pending | drafted | approved | posted | skipped
  aiDraft        String?   @db.Text   // AI-generated response draft
  postedAt       DateTime  // When the review was posted
  respondedAt    DateTime? // When we responded
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([clientId, platform])
  @@index([responseStatus])
  @@index([clientId, postedAt])
}

model ContentCalendar {
  id          Int       @id @default(autoincrement())
  clientId    Int
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month       Int       // 1-12
  year        Int
  posts       Json      // Array of planned post objects with content, platform, scheduledDate, status
  status      String    @default("draft") // draft | review | approved | active | completed
  generatedAt DateTime  @default(now())
  approvedAt  DateTime?
  approvedBy  String?
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([clientId, month, year])
  @@index([status])
}

model Report {
  id          Int       @id @default(autoincrement())
  clientId    Int
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month       Int
  year        Int
  data        Json      // Metrics snapshot: posts published, engagement, reviews, etc.
  summary     String?   @db.Text // AI-generated narrative summary
  pdfUrl      String?   // GCS URL for generated PDF
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([clientId, month, year])
}

model Invoice {
  id               Int       @id @default(autoincrement())
  clientId         Int
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  stripeInvoiceId  String?   @unique
  amount           Int       // Amount in cents
  currency         String    @default("usd")
  status           String    @default("draft") // draft | open | paid | void | uncollectible
  periodStart      DateTime
  periodEnd        DateTime
  paidAt           DateTime?
  dueDate          DateTime?
  pdfUrl           String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([clientId, status])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// CLIENT INTEGRATIONS (Pluggable Services)
// ─────────────────────────────────────────────────────────────

model ClientIntegration {
  id           Int       @id @default(autoincrement())
  clientId     Int
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  provider     String    // stripe | square | clover | opentable | resy | cloudbeds | mailchimp | google-analytics | meta-pixel | toast
  status       String    @default("pending") // pending | active | error | disconnected
  accountId    String?   // External account/merchant ID
  accessToken  String?   @db.Text  // Encrypted OAuth token
  refreshToken String?   @db.Text  // Encrypted OAuth refresh token
  expiresAt    DateTime? // Token expiry
  config       Json?     // Provider-specific config (e.g. location IDs, webhook URLs)
  scopes       String[]  // OAuth scopes granted
  displayName  String?   // Human-friendly name ("Anthologist Stripe", "Bobby J's Square")
  lastSyncAt   DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([clientId, provider])
  @@index([provider, status])
  @@index([clientId])
}

// ─────────────────────────────────────────────────────────────
// PUBLISHING PIPELINE
// ─────────────────────────────────────────────────────────────

model PublishJob {
  id          Int       @id @default(autoincrement())
  postId      Int       // Reference to SocialPost
  platform    String    // twitter | instagram | tiktok | bluesky | linkedin | facebook | gbp
  status      String    @default("pending") // pending | processing | published | failed | cancelled
  externalId  String?   // Platform's post ID after publishing
  externalUrl String?   // URL of published post
  error       String?   @db.Text
  attempts    Int       @default(0)
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, scheduledAt])
  @@index([postId])
}

// ─────────────────────────────────────────────────────────────
// TALENT PIPELINE (Rise Up → Showcase → Tour → Promote)
// ─────────────────────────────────────────────────────────────

model Artist {
  id              Int       @id @default(autoincrement())
  name            String
  slug            String    @unique
  genre           String?   // blues | soul | gospel | rock | folk | jazz | hip-hop | country | other
  city            String
  state           String    @default("MS")
  bio             String?   @db.Text
  photoUrl        String?
  socialLinks     Json?     // { instagram, tiktok, spotify, youtube, website, etc }
  source          String    @default("rise-up") // rise-up | scouted | submitted | referral
  status          String    @default("discovered") // discovered | contacted | showcasing | touring | alumni
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  notes           String?   @db.Text
  riseUpCohort    String?   // e.g. "2026-spring"
  discoveredAt    DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  showcases       ShowcaseSlot[]
  tourStops       TourStop[]
  tracks          Track[]
  splits          Split[]
  proRegistrations PRORegistration[]

  @@index([status])
  @@index([city, state])
  @@index([source])
  @@index([genre])
}

// ── MelodyVault: Track Catalog ──
model Track {
  id              Int       @id @default(autoincrement())
  title           String
  slug            String    @unique
  artistId        Int
  artist          Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  albumTitle      String?
  duration        Int?      // seconds
  genre           String?
  mood            String?   // uplifting | melancholic | energetic | chill | intense | warm
  bpm             Int?
  musicalKey      String?   // e.g. "D Major", "A Minor"
  isrc            String?   // International Standard Recording Code
  iswc            String?   // International Standard Musical Work Code
  audioUrl        String?   // GCS or R2 URL to master file
  waveformData    Json?     // pre-computed waveform for UI
  aiAnalysis      Json?     // { genre, mood, bpm, key, syncSuggestions, trendingInsights }
  metadata        Json?     // additional metadata (lyrics, credits, instruments)
  releaseDate     DateTime?
  status          String    @default("uploaded") // uploaded | analyzing | active | archived
  splits          Split[]
  syncSubmissions SyncSubmission[]
  proRegistrations PRORegistration[]
  royalties       RoyaltyPayment[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([artistId])
  @@index([genre, mood])
  @@index([status])
}

// ── MelodyVault: Splits Ledger ──
model Split {
  id          Int       @id @default(autoincrement())
  trackId     Int
  track       Track     @relation(fields: [trackId], references: [id], onDelete: Cascade)
  artistId    Int?
  artist      Artist?   @relation(fields: [artistId], references: [id])
  name        String    // contributor name (may not be a roster artist)
  email       String?
  role        String    // songwriter | producer | performer | engineer | featured
  sharePercent Float    // 0.0 to 100.0
  paypalEmail String?   // for royalty payouts
  status      String    @default("pending") // pending | confirmed | disputed
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([trackId, name, role])
  @@index([trackId])
  @@index([artistId])
}

// ── MelodyVault: Sync Marketplace ──
model SyncOpportunity {
  id            Int       @id @default(autoincrement())
  title         String
  description   String?   @db.Text
  projectType   String    // film | tv | ad | game | podcast | documentary | social
  genre         String?
  mood          String?
  budgetAmount  Int?      // dollars
  budgetType    String?   // buyout | 1-year | 2-year | perpetual
  deadline      DateTime?
  contactEmail  String?
  status        String    @default("open") // open | filled | expired | cancelled
  submissions   SyncSubmission[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, genre])
  @@index([deadline])
}

model SyncSubmission {
  id              Int       @id @default(autoincrement())
  trackId         Int
  track           Track     @relation(fields: [trackId], references: [id], onDelete: Cascade)
  opportunityId   Int
  opportunity     SyncOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  status          String    @default("submitted") // submitted | shortlisted | selected | rejected
  notes           String?   @db.Text
  submittedAt     DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([trackId, opportunityId])
  @@index([opportunityId])
}

// ── MelodyVault: PRO Rights Management ──
model PRORegistration {
  id            Int       @id @default(autoincrement())
  trackId       Int
  track         Track     @relation(fields: [trackId], references: [id], onDelete: Cascade)
  artistId      Int?
  artist        Artist?   @relation(fields: [artistId], references: [id])
  pro           String    // ASCAP | BMI | SESAC
  workId        String?   // W123456789
  registrationStatus String @default("pending") // pending | processing | registered | error
  registeredAt  DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([trackId, pro])
  @@index([registrationStatus])
}

// ── MelodyVault: Royalty Tracking ──
model RoyaltyPayment {
  id          Int       @id @default(autoincrement())
  trackId     Int
  track       Track     @relation(fields: [trackId], references: [id], onDelete: Cascade)
  source      String    // spotify | apple_music | youtube | sync | merch | direct
  period      String    // "2026-Q1" or "2026-03"
  grossAmount Float     // total before splits
  netAmount   Float     // after platform fees
  currency    String    @default("USD")
  streams     Int?
  downloads   Int?
  status      String    @default("pending") // pending | distributed | paid
  paidAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([trackId, period])
  @@index([source])
}

model Showcase {
  id          Int       @id @default(autoincrement())
  name        String    // e.g. "Rise Up Showcase — Spring 2026"
  venue       String    // "Ground Zero Blues Club" | "B.B. King's" | "Blues Room" | etc
  venueCity   String    // "Clarksdale" | "Memphis" | "Natchez"
  venueState  String    @default("MS")
  date        DateTime
  time        String?   // "7:00 PM CT"
  description String?   @db.Text
  capacity    Int?
  ticketPrice String?   // "$15" | "Free" | "$10-25"
  ticketUrl   String?
  status      String    @default("planning") // planning | confirmed | promoted | completed | cancelled
  eventId     Int?      // Link to Event model if also listed as an event
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  slots       ShowcaseSlot[]

  @@index([date, status])
  @@index([venue])
}

model ShowcaseSlot {
  id          Int       @id @default(autoincrement())
  showcaseId  Int
  showcase    Showcase  @relation(fields: [showcaseId], references: [id], onDelete: Cascade)
  artistId    Int
  artist      Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  setOrder    Int       @default(0)  // Performance order
  setLength   Int?      // Minutes
  status      String    @default("confirmed") // invited | confirmed | declined | performed
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([showcaseId, artistId])
  @@index([artistId])
}

model TourStop {
  id          Int       @id @default(autoincrement())
  artistId    Int
  artist      Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  venue       String
  venueCity   String
  venueState  String    @default("MS")
  date        DateTime
  time        String?
  guarantee   Int?      // Artist guarantee in cents
  doorDeal    String?   // "70/30" | "80/20" | "flat $500"
  ticketPrice String?
  status      String    @default("hold") // hold | confirmed | advanced | completed | cancelled
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([artistId, date])
  @@index([date, status])
  @@index([venue])
}

// ─── Snap & Share Photo System ───────────────────────────────
model PhotoSession {
  id          String   @id @default(cuid())
  code        String   @unique // short code for QR URL e.g. "blues-room-mar-15"
  name        String   // "Blues Room — March 15, 2026"
  location    String   // "The Big Muddy Inn"
  date        DateTime
  description String?
  coverImage  String?  // GCS URL
  status      String   @default("active") // active | archived
  photos      Photo[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Photo {
  id           String       @id @default(cuid())
  sessionId    String
  session      PhotoSession @relation(fields: [sessionId], references: [id])
  url          String       // GCS URL for full res
  thumbnailUrl String?      // GCS URL for thumbnail
  caption      String?
  sortOrder    Int          @default(0)
  shareCount   Int          @default(0)
  printOrders  Int          @default(0)
  status       String       @default("visible") // visible | hidden
  claims       PhotoClaim[]
  createdAt    DateTime     @default(now())
}

model PhotoClaim {
  id         String   @id @default(cuid())
  photoId    String
  photo      Photo    @relation(fields: [photoId], references: [id])
  name       String?
  email      String?
  instagram  String?
  shared     Boolean  @default(false)
  printOrder Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// PUBLICATIONS (Books, Zines, Print)
// ─────────────────────────────────────────────────────────────

model Publication {
  id              Int       @id @default(autoincrement())
  title           String
  slug            String    @unique
  subtitle        String?
  author          String    @default("Chase Pierson")
  description     String?   @db.Text
  longDescription String?   @db.Text   // Full book description / back cover copy
  category        String    @default("book") // book | zine | print | catalog
  format          String    @default("hardcover") // hardcover | softcover | digital | limited-edition
  pageCount       Int?
  dimensions      String?   // e.g. "10 x 10 inches"
  isbn            String?
  price           Int?      // Price in cents
  currency        String    @default("usd")
  coverImageUrl   String?   // Front cover
  backCoverUrl    String?   // Back cover
  previewImages   String[]  // Interior spread previews
  printPartner    String?   // e.g. "Blurb", "Lulu", "self"
  printUrl        String?   // URL to order (Blurb, Amazon, etc.)
  shopifyUrl      String?   // If sold through Shopify
  status          String    @default("draft") // draft | production | preorder | available | sold-out | archived
  edition         String?   // e.g. "First Edition", "Artist Proof"
  printRun        Int?      // Total copies in print run
  soldCount       Int       @default(0)
  relatedCity     String?   // natchez | clarksdale | etc.
  tags            String[]  // portrait | art | photography | inn | blues
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([category])
  @@index([relatedCity])
}

// ─────────────────────────────────────────────────────────────
// AUTH (NextAuth.js)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("viewer")  // admin | ops | artist | viewer
  
  // ── Onboarding & Personalization Matrix ──
  onboardingStep String   @default("pending_survey") // pending_survey | pending_asana | completed
  communicationChannels String[] // e.g. ["asana", "email", "google_chat"]
  communicationStyle    String?  // bulleted_brief | detailed_warm | data_heavy
  interfaceTheme        String   @default("minimal") // futuristic | retro | minimal
  asanaMemberId         String?
  communicationPrefsUpdatedAt DateTime?

  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// INN OPERATIONS (Launch Tracker + Delta Dawn)
// ============================================================

model LaunchTask {
  id           Int       @id @default(autoincrement())
  taskNumber   Int       @unique
  title        String
  session      Int       // 1-7 (work session grouping)
  sessionName  String    // e.g. "Quick Wins", "Google Business Profile"
  platform     String?   // e.g. "Google", "Facebook", "Yelp"
  timeEstimate String?   // e.g. "15 min", "1 hour"
  status       String    @default("pending") // pending, done, skipped
  assignedTo   String?   // "tracy", "amy", "chase"
  guide        String?   @db.Text // HTML step-by-step instructions
  link         String?   // external URL for the task
  requiresLogin Boolean  @default(false)
  contentPackSlug String? // FK reference to ContentPack.slug
  triggers     Json?     // array of trigger objects
  notes        Json?     @default("[]") // array of note objects
  completedAt  DateTime?
  completedBy  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  contentPack  ContentPack? @relation(fields: [contentPackSlug], references: [slug])
}

model ContentPack {
  slug     String @id // e.g. "google_description", "facebook_about"
  title    String
  sections Json   // array of { label: string, content: string }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks    LaunchTask[]
}

model OpsActivity {
  id        Int      @id @default(autoincrement())
  type      String   // "login", "task_completed", "task_skipped", "chat", "content_viewed"
  message   String
  userId    String?  // email
  userName  String?
  taskId    Int?     // optional reference to task number
  createdAt DateTime @default(now())
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  sessionId String
  role      String   // "user" or "assistant"
  content   String   @db.Text
  userId    String   // email of the user
  userName  String
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([userId])
}

// ─── BuyCurious Art Marketplace ──────────────────────────────
model ArtistProfile {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  bio         String?   @db.Text
  city        String?
  state       String?
  medium      String?   // painting, photography, sculpture, mixed media, textile, ceramics, printmaking
  profileImage String?  // GCS URL
  website     String?
  instagram   String?
  featured    Boolean   @default(false)
  status      String    @default("active") // active | inactive | pending
  artworks    Artwork[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Artwork {
  id          String        @id @default(cuid())
  artistId    String
  artist      ArtistProfile @relation(fields: [artistId], references: [id])
  title       String
  slug        String        @unique
  description String?       @db.Text
  medium      String?       // oil on canvas, digital print, photograph, etc.
  dimensions  String?       // "24x36 inches"
  year        Int?
  price       Int           // cents
  salePrice   Int?          // cents, optional sale price
  images      Json          // array of GCS URLs
  category    String?       // original, print, photograph, sculpture, craft
  edition     String?       // "1/50" or "open edition" or "original"
  available   Boolean       @default(true)
  featured    Boolean       @default(false)
  tags        String[]      // ["blues", "mississippi", "portrait", "landscape"]
  orderCount  Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ArtOrder {
  id          String   @id @default(cuid())
  artworkId   String
  buyerName   String
  buyerEmail  String
  amount      Int      // cents
  status      String   @default("pending") // pending | paid | shipped | delivered | cancelled
  shippingAddress Json?
  stripePaymentId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

