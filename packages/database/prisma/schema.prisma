  author          String    @default("Agent Swarm") // "AG", "CC", "Chase", etc.
  content         String    @db.Text
  tags            String[]  // e.g. ["architecture", "research", "musings"]
  sourceSystem    String?   // e.g. "cli", "web", "webhook"
  tokenCount      Int?      // Estimated tokens for RAG context packing logic
  status          String    @default("active") // active | archived
