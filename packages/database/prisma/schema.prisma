  slug              String    @unique              // URL-safe: slugify(name)-slugify(city)
  category          String
  subcategory       String?                        // e.g. "BBQ" under "Food & Drink"
  city              String
  state             String    @default("MS")       // 2-letter state code
  address           String?                        // Street address
  phone             String?                        // Primary phone (E.164 or 10-digit)
  zip               String?                        // 5-digit ZIP
  lat               Float?                         // Latitude (decimal degrees)
  lng               Float?                         // Longitude (decimal degrees)
  website           String?
  description       String    @db.Text
  contactName       String
  contactEmail      String
  tier              String    @default("free")     // free | main_street | the_route | hdx_ops
  spotlight         String?   @db.Text             // AI-generated editorial copy
  toolsOrigin       String?                        // Survey: where tools come from
  softwareSpend     String?                        // Survey: monthly software spend
  hearAbout         String?                        // How they found the directory
  active            Boolean   @default(false)      // Manually activated by admin
  visibility        String    @default("private")  // private | approved | featured — controls AI assistant access

  // ── External Data Sources ──
  googlePlaceId     String?   @unique              // Google Places place_id
  yelpBusinessId    String?   @unique              // Yelp business alias
  googleRating      Float?                         // Cached Google rating (1-5)
  googleReviewCount Int?                           // Cached Google review count
  yelpRating        Float?                         // Cached Yelp rating (1-5)
  yelpReviewCount   Int?                           // Cached Yelp review count
  hoursJson         Json?                          // Structured hours from Google Places
  photoUrls         String[]                       // Cached photo URLs (first 3)
  lastEnrichedAt    DateTime?                      // Last external data sync timestamp

