// ─────────────────────────────────────────────────────────────
// DEEP SOUTH DATA PLATFORM
// Phase 1: Vector search, economic data, enrichment pipeline
// ─────────────────────────────────────────────────────────────

// Polymorphic vector embeddings for semantic search.
// Uses Vertex AI text-embedding-005 (768 dimensions).
// Query via prisma.$queryRaw with pgvector <=> cosine distance operator.
model Embedding {
  id         Int                        @id @default(autoincrement())
  entityType String // "directory_business" | "article" | "client" | "transcript"
  entityId   String // Polymorphic FK (string to handle int and cuid IDs)
  chunkIndex Int                        @default(0) // Which chunk of the source text (0 for single-chunk entities)
  content    String                     @db.Text // The raw text that was embedded
  vector     Unsupported("vector(768)") // Vertex AI text-embedding-005 output
  model      String                     @default("text-embedding-005") // Embedding model used
  createdAt  DateTime                   @default(now())

  loreEntry LoreEntry?

  @@unique([entityType, entityId, chunkIndex])
  @@index([entityType])
}

// Census Bureau ACS 5-Year + County Business Patterns data.
// Free API, no key needed. Refresh annually.
model CensusData {
  id        Int      @id @default(autoincrement())
  geoType   String // "zip" | "county" | "msa" | "state"
  geoId     String // FIPS code or ZIP code
  geoName   String // "Adams County, MS" | "39120"
  dataset   String // "acs5" | "cbp" | "economic_census"
  variable  String // ACS variable code e.g. "B19013_001E" (median income)
  value     Float? // Null = data suppressed by Census (small populations)
  year      Int
  fetchedAt DateTime @default(now())

  @@unique([geoType, geoId, dataset, variable, year])
  @@index([geoId])
  @@index([variable, year])
}

// BLS LAUS, QCEW, OES + USDA ERS economic data.
// Free APIs. Refresh monthly (LAUS/QCEW) or annually (OES/USDA).
model EconomicIndicator {
  id        Int      @id @default(autoincrement())
  source    String // "bls_laus" | "bls_qcew" | "bls_oes" | "usda_ers"
  seriesId  String // BLS series ID e.g. "LAUCN280010000000003"
  geoType   String // "county" | "msa" | "state"
  geoId     String // FIPS code
  geoName   String // "Adams County, MS"
  period    String // "2025-Q4" | "2025-12" | "2025"
  indicator String // "unemployment_rate" | "avg_weekly_wage" | "establishments"
  value     Float
  fetchedAt DateTime @default(now())

  @@unique([source, seriesId, period])
  @@index([geoId, indicator])
  @@index([indicator, period])
}

// Async enrichment job queue. When a DirectoryBusiness is created/updated,
// jobs are queued for Google Places, Yelp, embedding, and spotlight generation.
// Processed by /api/cron/process-enrichment-queue every 5 minutes.
model EnrichmentJob {
  id          Int       @id @default(autoincrement())
  entityType  String // "directory_business"
  entityId    String // ID of the entity to enrich
  jobType     String // "google_places" | "yelp" | "embedding" | "spotlight" | "census"
  status      String    @default("pending") // "pending" | "processing" | "completed" | "failed"
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  error       String?   @db.Text // Error message if failed
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([status, jobType])
  @@index([entityType, entityId])
}

// ─────────────────────────────────────────────────────────────
// AGENT CONTEXT — Shared brain for the agent swarm
// ─────────────────────────────────────────────────────────────

/// Structured knowledge fragments — the database replaces markdown files
/// as the single source of truth for business context.
model AgentContext {
  id          Int       @id @default(autoincrement())
  domain      String // "finance", "operations", "strategy", "touring", "tech", "product", "brand"
  topic       String // "cap-table", "inn-occupancy", "pipeline-revenue", "pricing"
  key         String // unique identifier like "entity.hdi.ownership" or "decision.mbt-pricing"
  content     String    @db.Text // the actual knowledge (markdown)
  source      String // origin: "tax-db/ENTITY_REGISTRY.md", "agent:ledger", "memory:project_cap_table"
  confidence  Float     @default(1.0) // 0-1, decays over time for time-sensitive facts
  agentAuthor String? // which agent wrote this: "huck", "ledger", "delta-dawn", "rook", "chuck"
  visibility  String    @default("private") // private | public — controls AI assistant access
  validUntil  DateTime? // TTL for time-sensitive facts (null = permanent)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([domain, key])
  @@index([domain, topic])
  @@index([agentAuthor])
  @@index([confidence])
  @@index([visibility])
}

/// Agent action log — replaces AGENT_LEDGER.md
/// Every significant agent action gets recorded here.
model AgentAction {
  id        Int      @id @default(autoincrement())
  agent     String // "huck", "delta-dawn", "ledger", "chuck", "rook"
  action    String // "deployed", "fixed-bug", "created-report", "decision", "research"
  summary   String // one-line description
  detail    String?  @db.Text // full detail (markdown)
  domain    String // which area of the business
  impact    String? // "high", "medium", "low"
  createdAt DateTime @default(now())

  @@index([agent, createdAt])
  @@index([domain, createdAt])
}

// ─────────────────────────────────────────────────────────────
// SANDBOX MIRRORS (Phase 1.8) — staging before promotion to production
// Branch policy: when ToolRunContext.isSandbox, handlers MUST NOT write prod tables.
// DraftBusiness mirrors DirectoryBusiness fields used by rook.harvest.
// ─────────────────────────────────────────────────────────────

model DraftBusiness {
  id              Int     @id @default(autoincrement())
  createdByUserId String?
  createdBy       User?   @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  clientId        Int?
  client          Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  name              String
  slug              String  @unique
  category          String
  city              String
  state             String  @default("MS")
  address           String?
  phone             String?
  website           String?
  description       String  @db.Text
  contactName       String
  contactEmail      String
  tier              String  @default("free")
  googleRating      Float?
  googleReviewCount Int?
  active            Boolean @default(false)

  /// Set when promoted to DirectoryBusiness (Phase 1.9+)
  promotedDirectoryBusinessId Int? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdByUserId])
  @@index([clientId])
}

model DraftAction {
  id              Int     @id @default(autoincrement())
  createdByUserId String?
  createdBy       User?   @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  agent   String
  action  String
  summary String
  detail  String? @db.Text
  domain  String
  impact  String?

  createdAt DateTime @default(now())

  @@index([createdByUserId, createdAt])
}

model DraftContext {
  id              Int     @id @default(autoincrement())
  createdByUserId String?
  createdBy       User?   @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  domain      String
  topic       String
  key         String
  content     String    @db.Text
  source      String
  confidence  Float     @default(1.0)
  agentAuthor String?
  visibility  String    @default("private")
  validUntil  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([domain, key])
  @@index([createdByUserId])
}

/// Show Event — first-class entity spanning all 11 domains
/// One show entry triggers the 2:1 multiplier cascade
model ShowEvent {
  id          Int      @id @default(autoincrement())
  title       String // "Rise Up at the Blues Room"
  artist      String // Headliner name
  venue       String   @default("The Big Muddy Inn - Blues Room")
  dateTime    DateTime // When the show happens
  description String?  @db.Text
  ticketUrl   String? // Stripe or external ticket link
  ticketPrice Float? // Door price
  posterUrl   String? // Hero image / poster (GCS URL)
  status      String   @default("draft") // draft | published | archived | completed

  // Cross-domain cascade tracking
  radioEpisodeId String? // Links to Radio live session
  magazineBlurb  String? @db.Text // Generated magazine content
  dsdPartnerId   Int? // Cross-promo partner business
  cloudbedsCode  String? // "Blues & Beds" discount code
  socialCampaign String? @db.Text // Generated social posts JSON
  radioScript    String? @db.Text // Generated radio promo script

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, dateTime])
  @@index([artist])
}

/// Business decisions with rationale — queryable decision log
model Decision {
  id           Int      @id @default(autoincrement())
  title        String // "MBT pricing set to $99/mo"
  rationale    String   @db.Text // why this was decided
  decidedBy    String // "chase", "chase+tracy", "agent:rook"
  domain       String // "pricing", "operations", "strategy", "hiring", "product"
  status       String   @default("active") // "active", "superseded", "reversed"
  supersededBy Int? // ID of newer decision that replaces this one
  evidence     String?  @db.Text // supporting data, links, research
  createdAt    DateTime @default(now())

  @@index([domain, status])
  @@index([decidedBy])
}

/// Pending content drafts — generated by agents, approved by humans
model PendingDraft {
  id          Int       @id @default(autoincrement())
  channel     String // "social" | "magazine" | "radio" | "reviews"
  title       String
  content     String    @db.Text
  status      String    @default("pending") // "pending" | "approved" | "rejected" | "published"
  sourceType  String // "show_event" | "business" | "scheduled"
  sourceId    String?
  agentAuthor String?
  refinements String?   @db.Text
  approvedBy  String?
  approvedAt  DateTime?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, channel])
  @@index([sourceType, sourceId])
}

// Page-level content overrides from Edit Mode
model PageEdit {
  id        Int      @id @default(autoincrement())
  path      String // URL path, e.g. "/touring" or "/directory/fat-mamas"
  editId    String // DOM element ID, e.g. "edit-5" or "img-3"
  editType  String // "text" or "image"
  content   String   @db.Text // new text content or new image URL
  editedBy  String? // user email or "anonymous"
  active    Boolean  @default(true) // soft-delete: false = reverted
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([path, editId])
  @@index([path, active])
}

// ─────────────────────────────────────────────────────────────
// PRODUCTIONS — Video Production Pipeline
// ─────────────────────────────────────────────────────────────

model ProductionCampaign {
  id            Int      @id @default(autoincrement())
  name          String // "Fits In Your Hand"
  slug          String   @unique // "fits-in-your-hand"
  conceptNumber Int // 1-6
  tagline       String? // "An entire media ecosystem in a box that fits in your hand"
  status        String   @default("active") // active | archived
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  jobs ProductionJob[]

  @@index([status])
}

model ProductionJob {
  id         Int                @id @default(autoincrement())
  campaignId Int
  campaign   ProductionCampaign @relation(fields: [campaignId], references: [id])
  title      String // "The Box — :15"
  slug       String             @unique // "the-box-15"
  format     String // :15 | :30 | :60 | 3:00 | 10:00
  stage      String             @default("script") // script | voiceover | video | review | published

  // ── Script Fields ──
  veoPrompt      String? @db.Text // Veo visual generation prompt
  ttsScript      String? @db.Text // Voiceover script for TTS
  musicDirection String? @db.Text // Lyria / music bed direction
  textOverlays   String? @db.Text // Canva text overlays (JSON array)
  cta            String? // Call to action URL or text

  // ── Voice Settings ──
  voicePreset String @default("chase") // delta-dawn | catfish-carl | chase | etc.
  voiceSpeed  Float  @default(1.0)
  voicePitch  Float  @default(0)

  // ── Video Settings ──
  veoQuality    String @default("draft") // draft | premium
  videoDuration Int    @default(5) // seconds

  // ── Async Generation ──
  veoOperationId String? // Veo operation ID (null when not generating)

  // ── Approval ──
  approvalStatus String  @default("pending") // pending | approved | revision
  approvalNotes  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artifacts ProductionArtifact[]

  @@index([campaignId])
  @@index([stage])
  @@index([approvalStatus])
  @@index([veoOperationId])
}

model ProductionArtifact {
  id        Int           @id @default(autoincrement())
  jobId     Int
  job       ProductionJob @relation(fields: [jobId], references: [id])
  stage     String // script | voiceover | video | review | published
  type      String // voiceover | video | image | music | assembly
  gcsUrl    String // Full GCS public URL
  mimeType  String // audio/mpeg | video/mp4 | image/webp | etc.
  fileSize  Int? // bytes
  version   Int           @default(1) // increments on re-generation
  metadata  String?       @db.Text // JSON: duration, dimensions, model, etc.
  createdAt DateTime      @default(now())

  @@index([jobId, stage])
  @@index([jobId, type])
}

// ══════════════════════════════════════════════════════════════
// MBT Life — Community Coordination Platform
// measurablybetter.life consumer app models
// ══════════════════════════════════════════════════════════════

model CommunityProfile {
  id               String   @id @default(cuid())
  userId           String? // soft FK to User (optional — can exist without internal user)
  email            String?  @unique
  displayName      String
  bio              String?  @db.Text
  city             String
  state            String
  lat              Float?
  lng              Float?
  tier             String   @default("free") // free | life | business
  stripeCustomerId String?
  skills           String[] // quick-access skill tags
  sandbox          Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([city, state])
  @@index([tier])
  @@index([email])
}

model SkillListing {
  id           String   @id @default(cuid())
  profileId    String // soft FK to CommunityProfile
  skill        String
  description  String?  @db.Text
  category     String // trades | professional | creative | tech | domestic | other
  availability String? // weekends | evenings | flexible | by-appointment
  rateNote     String? // "trade only" | "negotiable" | etc
  sandbox      Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([category])
  @@index([profileId])
  @@index([skill])
}

model TaskPost {
  id           String   @id @default(cuid())
  authorId     String // soft FK to CommunityProfile
  title        String
  description  String   @db.Text
  skillsNeeded String[]
  status       String   @default("open") // open | claimed | in-progress | done
  claimedById  String? // soft FK to CommunityProfile
  valueType    String   @default("trade") // trade | cash | credit | volunteer
  valueNote    String?
  city         String
  state        String
  sandbox      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, city])
  @@index([authorId])
}

model TimeExchange {
  id          String   @id @default(cuid())
  providerId  String // soft FK to CommunityProfile (who did the work)
  receiverId  String // soft FK to CommunityProfile (who received)
  taskPostId  String? // soft FK to TaskPost (optional link)
  hours       Float
  skill       String
  description String?  @db.Text
  status      String   @default("logged") // logged | confirmed | disputed
  sandbox     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([providerId])
  @@index([receiverId])
}

model ToolLibraryItem {
  id           String   @id @default(cuid())
  ownerId      String // soft FK to CommunityProfile
  name         String
  description  String?
  category     String // power-tools | hand-tools | kitchen | garden | other
  available    Boolean  @default(true)
  borrowedById String? // soft FK to CommunityProfile
  city         String
  state        String
  sandbox      Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([city, category])
  @@index([ownerId])
}

model ContributedListing {
  id            String   @id @default(cuid())
  contributorId String // soft FK to CommunityProfile
  businessName  String
  category      String
  city          String
  state         String
  address       String?
  phone         String?
  website       String?
  description   String   @db.Text
  status        String   @default("pending") // pending | approved | rejected
  reviewNote    String?  @db.Text // AI or human feedback
  directoryId   Int? // FK to DirectoryBusiness when approved
  sandbox       Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([status])
  @@index([contributorId])
}

model ContributorCredit {
  id        String   @id @default(cuid())
  profileId String // soft FK to CommunityProfile
  amount    Int      @default(1)
  reason    String // directory_submission | article_published | skill_verified
  sourceId  String? // FK to the thing that earned it
  sandbox   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([profileId])
}

// ══════════════════════════════════════════════════════════════
// Lookbook — Illustration review comments
// ══════════════════════════════════════════════════════════════

model LookbookComment {
  id        Int      @id @default(autoincrement())
  style     String // e.g. "01-woodcut"
  image     String // e.g. "community-gathering"
  text      String   @db.Text
  author    String? // email or name
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([style, image])
}

// ══════════════════════════════════════════════════════════════
// TOURING — Venue Intelligence, Accommodation, Route Planning
// R&D agent populates these. Powers tour planning for the Sprinter van.
// ══════════════════════════════════════════════════════════════

/// Touring-specific venue data that extends DirectoryBusiness.
/// Soft FK to DirectoryBusiness via directoryBusinessId (optional).
model TouringVenue {
  id                   Int                @id @default(autoincrement())
  name                 String
  slug                 String             @unique
  city                 String
  state                String             @default("MS")
  address              String?
  lat                  Float?
  lng                  Float?
  capacity             Int? // Max audience
  stageWidth           Float? // feet
  stageDepth           Float? // feet
  soundSystem          String?            @db.Text // PA description
  backlineAvailable    String?            @db.Text // "Full backline" | "Drums + bass amp" | "BYO"
  loadInNotes          String?            @db.Text // "Street level, double doors, no dock"
  greenRoom            Boolean            @default(false)
  greenRoomNotes       String?
  parkingSpaces        Int? // For the Sprinter
  sprinterAccess       Boolean            @default(true) // Can a 12-passenger Sprinter park/load?
  venueType            String             @default("club") // club | theater | outdoor | house_concert | festival | juke_joint
  bookingContactName   String?
  bookingContactEmail  String?
  bookingContactPhone  String?
  typicalGuaranteeLow  Int? // cents — low end of typical guarantee
  typicalGuaranteeHigh Int? // cents — high end
  doorDealTerms        String? // "70/30 after $200" | "straight 80/20"
  seasonalNotes        String?            @db.Text // "Dead Jan-Feb, peaks Oct"
  notes                String?            @db.Text // Internal touring notes
  isPublic             Boolean            @default(true) // false = guarantees/contacts hidden from public DB
  directoryBusinessId  Int?
  directoryBusiness    DirectoryBusiness? @relation(fields: [directoryBusinessId], references: [id], onDelete: SetNull)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  routeStops TourRouteStop[]

  @@index([city, state])
  @@index([venueType])
  @@index([capacity])
  @@index([isPublic])
  @@index([directoryBusinessId])
}

/// Band-friendly accommodations along touring corridors.
model TouringHotel {
  id                  Int                @id @default(autoincrement())
  name                String
  city                String
  state               String             @default("MS")
  address             String?
  lat                 Float?
  lng                 Float?
  phone               String?
  website             String?
  rateLow             Int? // cents per night — low season
  rateHigh            Int? // cents per night — high season
  roomCount           Int?
  amenities           String[] // ["wifi", "parking", "breakfast", "pool", "laundry"]
  bandFriendly        Boolean            @default(true) // Late check-in, noise tolerance, etc
  bandFriendlyNotes   String?            @db.Text
  sprinterParking     Boolean            @default(false) // Lot can fit a 12-passenger Sprinter
  nearbyVenues        Json? // [{ venueId: 1, distanceMiles: 0.5 }]
  notes               String?            @db.Text
  isPublic            Boolean            @default(true)
  directoryBusinessId Int?
  directoryBusiness   DirectoryBusiness? @relation(fields: [directoryBusinessId], references: [id], onDelete: SetNull)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  routeStops TourRouteStop[]

  @@index([city, state])
  @@index([city, state, isPublic])
  @@index([isPublic])
  @@index([directoryBusinessId])
}

/// Pre-built touring corridors with budget estimates.
/// A route is a sequence of stops (venue + hotel pairs).
model TourRoute {
  id                   Int      @id @default(autoincrement())
  name                 String // "Delta Run: Natchez → Clarksdale → Memphis"
  slug                 String   @unique
  description          String?  @db.Text
  totalMiles           Float? // Total driving distance
  estimatedDriveHours  Float? // Total drive time
  budgetLowCents       Int? // Low-end total budget in cents
  budgetMidCents       Int? // Mid-range budget in cents
  budgetHighCents      Int? // High-end budget in cents
  budgetBreakdown      Json? // { fuel, lodging, perDiem, musicians, sound, promo, contingency }
  revenueEstimate      Json? // { door, bar, content, innLift }
  seasonRecommendation String? // "Best: Mar-May, Sep-Nov. Avoid: Jul-Aug (heat)"
  bandSize             Int      @default(5) // Musicians + crew for budget calc
  notes                String?  @db.Text
  isPublic             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  stops TourRouteStop[]

  @@index([isPublic])
}

/// Individual stop on a touring route — links venue + hotel + sequence.
model TourRouteStop {
  id                 Int           @id @default(autoincrement())
  routeId            Int
  route              TourRoute     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  venueId            Int?
  venue              TouringVenue? @relation(fields: [venueId], references: [id])
  hotelId            Int?
  hotel              TouringHotel? @relation(fields: [hotelId], references: [id])
  stopOrder          Int // 1, 2, 3...
  city               String
  state              String        @default("MS")
  nightsStay         Int           @default(1) // Nights at this stop
  driveFromPrevMiles Float? // Miles from previous stop
  driveFromPrevHours Float? // Drive time from previous stop
  notes              String?       @db.Text
  createdAt          DateTime      @default(now())

  @@unique([routeId, stopOrder])
  @@index([routeId])
  @@index([venueId])
  @@index([hotelId])
}

/// Musician-friendly restaurants along touring corridors.
/// Late-night spots, per diem-friendly, where bands eat after shows.
model TouringRestaurant {
  id                  Int                @id @default(autoincrement())
  name                String
  city                String
  state               String             @default("MS")
  address             String?
  phone               String?
  website             String?
  cuisine             String? // "BBQ" | "Soul food" | "Cajun" | "Diner" | "Mexican" | etc
  priceRange          String             @default("$$") // "$" | "$$" | "$$$"
  lateNight           Boolean            @default(false) // Open past 10pm?
  closingTime         String? // "2:00 AM" | "Midnight" | "11:00 PM"
  musicianFriendly    Boolean            @default(true) // Large groups, noise tolerant, post-show vibe
  musicianNotes       String?            @db.Text // "Free shot for musicians" | "Green room backstage meals" | etc
  nearbyVenues        Json? // [{ venueName: "Ground Zero", walkingMinutes: 5 }]
  isPublic            Boolean            @default(true)
  directoryBusinessId Int?
  directoryBusiness   DirectoryBusiness? @relation(fields: [directoryBusinessId], references: [id], onDelete: SetNull)
  corridorCityId      Int?
  corridorCity        CorridorCity?      @relation(fields: [corridorCityId], references: [id])
  createdAt           DateTime           @default(now())

  @@index([city, state])
  @@index([city, state, lateNight])
  @@index([lateNight])
  @@index([corridorCityId])
  @@index([directoryBusinessId])
}

/// Cities along the touring corridor with logistics and context.
/// The backbone of tour route planning.
model CorridorCity {
  id                 Int      @id @default(autoincrement())
  name               String
  state              String
  slug               String   @unique // "natchez-ms" | "clarksdale-ms" | "memphis-tn"
  population         Int?
  role               String   @default("stopover") // "home_base" | "major_hub" | "talent_supply" | "delta_gateway" | "stopover" | "cultural_landmark"
  corridorOrder      Int // 1=NOLA, 2=Baton Rouge, ... 13=Memphis
  driveFromPrevMiles Float? // Miles from previous corridor city
  driveFromPrevHours Float? // Drive time from previous city
  musicScene         String?  @db.Text // Overview of local music scene
  logisticsNotes     String?  @db.Text // Parking, load-in, local quirks
  seasonalNotes      String?  @db.Text // "Dead Jul-Aug" | "Festival season Apr-May"
  keyContacts        Json? // [{ name, role, email, phone }]
  isPublic           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  restaurants TouringRestaurant[]
  businesses  DirectoryBusiness[]

  @@unique([name, state])
  @@index([corridorOrder])
}

// ─────────────────────────────────────────────────────────────
// POSTGRES CONSTELLATION LAYER — derived graph over touring + directory
// Nodes/edges populated by scripts/graph-lab/seed-constellation.ts
// Materialized views: packages/database/prisma/sql/constellation_views.sql
// ─────────────────────────────────────────────────────────────

model ConstellationNode {
  id         String   @id @default(cuid())
  /// venue | hotel | restaurant | city | route | directory_business
  entityType String
  /// Stable string id, e.g. "42" for numeric PKs
  entityId   String
  label      String
  subtitle   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([entityType, entityId])
  @@index([entityType])
}

model ConstellationEdge {
  id        String   @id @default(cuid())
  fromType  String
  fromId    String
  toType    String
  toId      String
  /// directory_link | corridor_city | route_stop_venue | route_stop_hotel | route_sequence
  relation  String
  weight    Float    @default(1)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([fromType, fromId])
  @@index([toType, toId])
  @@index([relation])
}

// ─────────────────────────────────────────────────────────────
// EDITORIAL BUREAU (Phase 2.1)
// ─────────────────────────────────────────────────────────────

model Brand {
  id                 String             @id @default(cuid())
  slug               String             @unique
  name               String
  jobs               Job[]
  /// Studio C production ops back-relations (added 2026-05-01).
  productionClientId String?
  productionClient   ProductionClient?  @relation(fields: [productionClientId], references: [id])
  brandKit           BrandKit?
  studioShows        StudioShow[]
  studioJobs         StudioJob[]        @relation("StudioJobBrand")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([productionClientId])
}

model StyleGuide {
  id               String   @id @default(cuid())
  name             String
  persona          String // e.g. "Tracy", "Amy", "CEO"
  toneWeight       Float // e.g. 0.8 to represent intensity of tone
  forbiddenPhrases String[] // Array of phrases to penalize in checking
  samples          String[] // Few-shot snippets
  jobs             Job[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([persona])
  @@index([persona, createdAt])
}

model Job {
  id                 String        @id @default(cuid())
  toolId             String
  params             Json
  editorialStatus    String        @default("DRAFT") // DRAFT | AI_READY | HUMAN_REVIEW | LIVE
  assignedHumanId    String?
  assignedHuman      User?         @relation(fields: [assignedHumanId], references: [id], onDelete: SetNull)
  brandId            String?
  brand              Brand?        @relation(fields: [brandId], references: [id])
  styleGuideId       String?
  styleGuide         StyleGuide?   @relation(fields: [styleGuideId], references: [id])
  /// AI / producer draft (HTML or plain text — editor normalizes on save)
  draftContent       String?       @db.Text
  /// Editor-in-Chief revision (Tracy / Amy lane)
  humanEditedContent String?       @db.Text
  /// Red Pen (Gemma / fallback) structured notes + suggested fixes
  redPenNotes        String?       @db.Text
  visualAssets       VisualAsset[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([editorialStatus])
  @@index([assignedHumanId])
  @@index([brandId])
  @@index([styleGuideId])
}

/// Radio / Inn / studio capture — Network Highlight copy + linked `VisualAsset` rows (optional `Job`).
model MediaSession {
  id                      String        @id @default(cuid())
  title                   String?
  venue                   String        @default("Big Muddy Radio Studio")
  recordedAt              DateTime      @default(now())
  endedAt                 DateTime?
  /// recorded | transcribed | highlight_ready | published
  status                  String        @default("recorded")
  networkHighlightSnippet String?       @db.Text
  sourceRecordingUrl      String?
  visualAssets            VisualAsset[]
  performances            Performance[]
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@index([recordedAt])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// BIG MUDDY MUSIC VERTICAL (Sovereign Stage + Radio Studio)
// Links roster `Artist` to physical `Venue` and ingest `MediaSession`.
// ─────────────────────────────────────────────────────────────

model Venue {
  id           Int           @id @default(autoincrement())
  slug         String        @unique
  name         String
  /// inn_stage | radio_studio | outdoor | partner
  kind         String        @default("inn_stage")
  address      String?
  city         String        @default("Natchez")
  state        String        @default("MS")
  performances Performance[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([kind])
  @@index([city, state])
}

/// Scheduled or completed show — headliner is existing talent-pipeline `Artist`.
model Performance {
  id             Int           @id @default(autoincrement())
  slug           String?       @unique
  title          String?
  artistId       Int
  artist         Artist        @relation(fields: [artistId], references: [id], onDelete: Restrict)
  venueId        Int
  venue          Venue         @relation(fields: [venueId], references: [id], onDelete: Restrict)
  mediaSessionId String?
  mediaSession   MediaSession? @relation(fields: [mediaSessionId], references: [id], onDelete: SetNull)
  scheduledAt    DateTime
  endedAt        DateTime?
  /// scheduled | soundcheck | live | completed | cancelled
  status         String        @default("scheduled")
  posterUrl      String?
  socialSnippet  String?       @db.Text
  vipNotes       String?       @db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  mediaAssets    MediaAsset[]

  @@index([venueId, scheduledAt])
  @@index([artistId])
  @@index([status])
  @@index([mediaSessionId])
}

/// Captured audio/video/still tied to a `Performance` (flywheel media output).
model MediaAsset {
  id              String       @id @default(cuid())
  performanceId   Int?
  performance     Performance? @relation(fields: [performanceId], references: [id], onDelete: SetNull)
  kind            String       @default("audio") // audio | video | image | transcript
  url             String
  mimeType        String?
  durationSeconds Int?
  metadata        Json?
  createdAt       DateTime     @default(now())

  @@index([performanceId])
  @@index([kind])
}

model VisualAsset {
  id                  String        @id @default(cuid())
  jobId               String?
  job                 Job?          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  mediaSessionId      String?
  mediaSession        MediaSession? @relation(fields: [mediaSessionId], references: [id], onDelete: SetNull)
  aiPlaceholderUrl    String?
  finalPhotographyUrl String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([jobId])
  @@index([mediaSessionId])
}

// ─────────────────────────────────────────────────────────────
// ECONOMIC ENGINE (Sovereign Wallet Tracker)
// ─────────────────────────────────────────────────────────────

model ContributionLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String
  fileType  String?
  sourceId  String? // References Lore or VisualAsset ID
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Append-only credit audit (burn / earn). Prefer this over mutating `User.credits` without a row.
model CreditLedger {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Signed delta: positive = earn, negative = burn
  change       Int
  reason       String // signing_bonus | daily_burn | lore_submit | admin_adjust | purchase_bypass | barter | contest_entry
  balanceAfter Int?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([reason])
}

/// Power-map node (Who's Who). Distinct from sales `Lead` — optimized for graph + Vertex traversal.
model Entity {
  id             String   @id @default(cuid())
  displayName    String
  industry       String
  /// 1–10 regional influence heuristic
  powerRating    Int      @default(5)
  connections    Json     @default("{}")
  notes          String?  @db.Text
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  version        Int      @default(1)
  supersededById String?
  supersededBy   Entity?  @relation("EntityVersion", fields: [supersededById], references: [id], onDelete: SetNull)
  superseded     Entity[] @relation("EntityVersion")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([industry])
  @@index([powerRating])
  @@index([industry, powerRating])
  @@index([userId])
  @@index([supersededById])
}

/// First-class lore unit for RAG + provenance (parallel to legacy `Lore` contributor table).
model LoreEntry {
  id              String      @id @default(cuid())
  /// raw | vetted | lore_media | clearinghouse | scout
  namespace       String
  title           String?
  body            String      @db.Text
  sourceUrl       String?
  /// 0–1 model / Vertex uncertainty; low values surface a human review queue
  confidenceScore Float?
  embeddingId     Int?        @unique
  embedding       Embedding?  @relation(fields: [embeddingId], references: [id], onDelete: SetNull)
  submitterId     String?
  submitter       User?       @relation(fields: [submitterId], references: [id], onDelete: SetNull)
  /// When true, exclude PII from city-facing aggregates; still usable for RAG with redacted provenance
  isAnonymized    Boolean     @default(false)
  verifiedAt      DateTime?
  version         Int         @default(1)
  supersededById  String?
  supersededBy    LoreEntry?  @relation("LoreVersion", fields: [supersededById], references: [id], onDelete: SetNull)
  superseded      LoreEntry[] @relation("LoreVersion")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([namespace])
  @@index([confidenceScore])
  @@index([submitterId])
  @@index([isAnonymized])
  @@index([supersededById])
}

/// Scout / orchestration job record for autonomous agents (Vertex-backed tasks).
model AgentTask {
  id          String    @id @default(cuid())
  agent       String
  missionType String // scout | harvest | transcribe | embed | other
  status      String    @default("pending") // pending | running | completed | failed | cancelled
  input       Json?
  result      Json?
  error       String?   @db.Text
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  traces ReasoningTrace[]

  @@index([status, missionType])
  @@index([createdAt])
}

model Lore {
  id           String   @id @default(cuid())
  sourceFile   String
  type         String // manuals | journals | sops
  rawText      String   @db.Text
  verified     Boolean  @default(false) // Vetting Flag
  isAnonymized Boolean  @default(false) // Privacy filter for Government Subsidized heat maps
  submitterId  String?
  submitter    User?    @relation(fields: [submitterId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([verified])
  @@index([isAnonymized])
  @@index([type])
  @@index([submitterId])
}

// ─────────────────────────────────────────────────────────────
// SOVEREIGN CONTESTS (Community flywheel)
// ─────────────────────────────────────────────────────────────

model Contest {
  id              String       @id @default(cuid())
  title           String
  description     String?      @db.Text
  rules           Json         @default("{}")
  startDate       DateTime
  endDate         DateTime
  prizePool       Json         @default("{}")
  entryFeeCredits Int          @default(0)
  /// image | audio | video | lore
  submissionType  String       @default("image")
  /// draft | published | closed
  status          String       @default("draft")
  organizerId     String?
  organizer       User?        @relation("ContestOrganizer", fields: [organizerId], references: [id], onDelete: SetNull)
  submissions     Submission[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status])
  @@index([status, startDate])
  @@index([organizerId])
  @@index([endDate])
}

model Submission {
  id         String   @id @default(cuid())
  contestId  String
  contest    Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentUrl String
  votes      Int      @default(0)
  /// PENDING | APPROVED | REJECTED
  status     String   @default("PENDING")
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([contestId])
  @@index([userId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// STUDIO C — Video production request pipeline
// Any HDI brand submits → Studio C accepts → produces → delivers
// ─────────────────────────────────────────────────────────────

model StudioCRequest {
  id            String    @id @default(cuid())
  clientBrand   String // big-muddy | bearsville | dsd | tuthill | magazine
  clientId      Int? // FK to Client if DSD merchant
  requestType   String // session-recording | promo-video | property-tour | social-clips | bts | documentary
  brief         String    @db.Text
  location      String? // Shoot location (default: Utopia Studios, Bearsville NY)
  preferredDate DateTime?
  budget        String? // "included-in-tier" | dollar amount | "quote-requested"
  status        String    @default("submitted") // submitted | accepted | scheduled | shooting | editing | review | delivered | archived
  assignedTo    String? // Crew member name
  jobId         Int? // FK to ProductionJob when accepted and converted
  notes         String?   @db.Text
  /// Call sheet / session ops: engineer, musicians, equipment, catering, times (JSON)
  callSheet     Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([clientBrand])
  @@index([clientId])
}

// ─────────────────────────────────────────────────────────────
// SIGNAGE — YouTube + Sovereign ticker (display routes)
// ─────────────────────────────────────────────────────────────

model DisplayChannel {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  youtubeChannelId String?
  youtubeVideoId   String?
  /// Passed to ad auctioneer as venue key for weighting
  venueKey         String?
  config           Json?    @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([slug])
}

// ─────────────────────────────────────────────────────────────
// SOVEREIGN MARKET (Ad Exchange)
// ─────────────────────────────────────────────────────────────

model AdCampaign {
  id           String   @id @default(cuid())
  title        String
  sponsorId    String
  sponsor      User     @relation("AdSponsor", fields: [sponsorId], references: [id])
  budget       Int // Credits authorized for campaign
  bidAmount    Int      @default(10) // Credits per impression
  status       String   @default("ACTIVE") // ACTIVE | PAUSED | DEPLETED
  targetVenues Json? // Array of venue/business IDs or categories
  assetUrl     String? // Reference to VisualAsset
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  impressions ImpressionLog[]

  @@index([status])
  @@index([sponsorId])
}

model ImpressionLog {
  id           String     @id @default(cuid())
  campaignId   String
  campaign     AdCampaign @relation(fields: [campaignId], references: [id])
  venueHostId  String // $500 tier Host User ID
  payoutAmount Int // Credits shared from impression
  displayedAt  DateTime   @default(now())

  @@index([campaignId])
  @@index([venueHostId])
}

// ─────────────────────────────────────────────────────────────
// PLATFORM PRIMITIVES (RBAC, Traces, Nodes, Webhooks)
// ─────────────────────────────────────────────────────────────

model ReasoningTrace {
  id          String    @id @default(cuid())
  taskId      String
  task        AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  prompt      String    @db.Text
  contextUsed Json?
  rawOutput   String    @db.Text
  createdAt   DateTime  @default(now())

  @@index([taskId])
}

model Group {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  members     GroupMember[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("MEMBER") // ADMIN | MEMBER | VIEWER
  createdAt DateTime @default(now())

  @@unique([groupId, userId])
}

model ApiKey {
  id         String    @id @default(cuid())
  keyHash    String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?

  @@index([userId])
}

model PhysicalNode {
  id        String    @id @default(cuid())
  name      String    @unique
  type      String // SERVER | KIOSK | TV
  status    String    @default("PENDING") // ONLINE | OFFLINE | PENDING
  ipAddress String?
  lastSeen  DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
  @@index([type])
}

model WebhookSubscription {
  id        String   @id @default(cuid())
  url       String
  event     String // e.g. "lore.created", "ad.depleted"
  /// stripe | asana | internal | custom
  provider  String?
  secret    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([event, isActive])
  @@index([provider])
}

// ══════════════════════════════════════════════════════════════
// PRODUCT CATALOG — Features, Tiers, Bundles
// The marketplace layer. Lore → Intelligence → Economy → Bureau.
// ══════════════════════════════════════════════════════════════

model ProductFeature {
  id              Int       @id @default(autoincrement())
  slug            String    @unique // e.g. "business-listing", "magazine-feature"
  name            String // e.g. "Business Listing Sync"
  category        String // software | media | creative | operations
  description     String?   @db.Text // what it does for the client
  competitor      String? // who we replace (e.g. "Yext")
  competitorPrice Int? // their monthly cost in cents
  isUnique        Boolean   @default(false) // true = moat feature (magazine, radio, photo)
  status          String    @default("planned") // planned | building | shipped | deprecated
  shippedAt       DateTime?
  sortOrder       Int       @default(0)
  tags            String[]  @default([]) // ["core", "media", "moat", "saas-replacement"]
  metadata        Json? // parity verdict, honest claim, gap analysis
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  bundles BundleFeature[]

  @@index([category])
  @@index([status])
}

model ProductBundle {
  id           Int      @id @default(autoincrement())
  slug         String   @unique // e.g. "starter", "media", "restaurant"
  name         String
  description  String?  @db.Text
  market       String   @default("general") // general | restaurant | hotel | musician | venue
  priceMonthly Int? // cents (null = TBD)
  priceAnnual  Int? // cents (null = TBD)
  isActive     Boolean  @default(false)
  sortOrder    Int      @default(0)
  metadata     Json? // stripe price ID, launch date, notes
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  features BundleFeature[]

  @@index([market])
  @@index([isActive])
}

model BundleFeature {
  id        Int     @id @default(autoincrement())
  bundleId  Int
  featureId Int
  limit     String? // "4/week", "1/year", "3 competitors", null = unlimited
  notes     String? // tier-specific notes

  bundle  ProductBundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  feature ProductFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([bundleId, featureId])
  @@index([bundleId])
  @@index([featureId])
}

// ══════════════════════════════════════════════════════════════
// PROTOCOL EXPANSION — GMB, Etsy, Hootsuite
// Multi-Tenant Sovereign E-Commerce & Broadcast Hub
// ══════════════════════════════════════════════════════════════

model BusinessProfile {
  id        String  @id @default(cuid())
  namespace String // e.g. BEARSVILLE_CREATIVE, DEEP_SOUTH_DIRECTORY
  name      String
  address   String?
  city      String?
  state     String?
  zip       String?
  lat       Float?
  lng       Float?
  hoursJson Json?
  mapData   Json?
  ownerId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store MarketplaceStore?

  @@index([namespace])
  @@index([ownerId])
}

model Vendor {
  id         String             @id @default(cuid())
  namespace  String
  name       String
  bio        String?            @db.Text
  userId     String? // System user ID mapped to this vendor
  payoutInfo Json?
  stores     MarketplaceStore[]
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([namespace])
}

model MarketplaceStore {
  id                String            @id @default(cuid())
  namespace         String
  name              String
  vendorId          String
  vendor            Vendor            @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  businessProfileId String?           @unique
  businessProfile   BusinessProfile?  @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
  description       String?           @db.Text
  supplies          ApprovedSupply[]
  affiliate         AffiliateProgram?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([namespace])
  @@index([vendorId])
}

model ApprovedSupply {
  id          String           @id @default(cuid())
  storeId     String
  store       MarketplaceStore @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sku         String           @unique
  name        String
  priceCents  Int
  inventory   Int              @default(0)
  autoReorder Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([storeId])
}

model AffiliateProgram {
  id             String           @id @default(cuid())
  storeId        String           @unique
  store          MarketplaceStore @relation(fields: [storeId], references: [id], onDelete: Cascade)
  commissionRate Float // e.g. 0.15 for 15%
  terms          String?          @db.Text
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model SocialCampaign {
  id        String         @id @default(cuid())
  namespace String
  title     String
  objective String?
  /// Hootsuite / Editorial Bureau campaign posts (distinct from legacy `SocialPost` tied to `SocialAccount`).
  posts     CampaignPost[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([namespace])
}

model CampaignPost {
  id           String         @id @default(cuid())
  campaignId   String
  campaign     SocialCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  content      String         @db.Text
  platforms    Json // e.g. ["instagram", "twitter"]
  scheduledFor DateTime?
  status       String         @default("DRAFT") // DRAFT | SCHEDULED | PUBLISHED | FAILED
  mediaUrls    Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([campaignId])
  @@index([status])
}

/// Guided onboarding progress for new team members (Amy first, Tracy and
/// future hires later). Powers /admin/onboarding/[role] — a Delta Dawn
/// chat-led experience that walks them through first-day setup.
///
/// Keyed by email (not user id) so it works with session-based auth without
/// requiring a full User table join. Resumable across sessions — partial
/// form drafts live in currentTaskState as JSON, auto-saved every ~1.5s
/// while the user types.
model OnboardingProgress {
  id               Int       @id @default(autoincrement())
  userEmail        String    @unique // keyed by auth session email
  role             String // "amy" | "tracy" | "future-hire"
  completedTasks   String[] // ordered list of completed task ids
  currentTaskId    String? // task the user is actively on (may differ from next-uncompleted if they jumped back)
  currentTaskState Json? // per-task partial state (form drafts, OAuth in-progress, etc.)
  notifPrefs       Json? // { email, asana, sms, googleChat } set in task 8
  lastSeenAt       DateTime  @default(now()) // updated on every page load — powers "welcome back"
  sessionCount     Int       @default(1) // increments when lastSeenAt is > 1 hour old
  startedAt        DateTime  @default(now())
  completedAt      DateTime? // set when all tasks finished
  updatedAt        DateTime  @updatedAt

  @@index([role])
  @@index([lastSeenAt])
}

// ─────────────────────────────────────────────────────────────
// PHASE C — MBT PLATFORM MODULES (added 2026-04-18 evening)
// Models for the 6 platform-build blocks. Designed additive-only —
// no existing models touched. New module packages live at
// packages/modules/{commerce,booking,finance,broadcast,events}.
// ─────────────────────────────────────────────────────────────

// ─── Block 1 · Commerce Module ───────────────────────────────
// Subscription billing infrastructure + one-off product checkout.
// Powers: Records recurring label services, Tuthill realtor packages,
// Radio sponsor packages, Inn direct booking add-ons, future merch.

/// A pricing plan template — the catalog entry. Per-tenant, per-product.
/// Multiple Subscription instances reference one Plan.
model Plan {
  id              String    @id @default(cuid())
  tenantId        String // "big-muddy", "tuthill", "studio-c", "dctv", "bearsville"
  brand           String // "records", "tuthill", "radio", "inn", "magazine", "cpp", "studio-c"
  slug            String // "records-silver", "tuthill-pro", "radio-monthly"
  name            String // human-readable display name
  description     String    @db.Text
  priceCents      Int // in cents
  currency        String    @default("usd")
  interval        String // "month" | "year" | "one_time" (one_time is Product, kept here for unified pricing surface)
  intervalCount   Int       @default(1) // every N intervals (e.g., quarterly = interval=month, count=3)
  trialDays       Int       @default(0)
  active          Boolean   @default(true)
  features        Json // array of feature bullet strings + flags consumed by feature-gating
  metadata        Json? // arbitrary tenant/brand-specific
  stripePriceId   String?   @unique // populated when Plan synced to Stripe
  stripeProductId String? // Stripe Product (parent of all Prices)
  // Tier 3 platform fee — when this Plan represents a vendor's recurring
  // service powered by MBT modules, MBT takes this % of the recurring revenue.
  // 0 = internal tooling (no rev share). 15-30 typical range for vendor-delivered.
  platformFeePercent Decimal? @db.Decimal(5, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subscriptions   Subscription[]

  @@unique([tenantId, slug])
  @@index([tenantId, brand, active])
  @@index([active])
}

/// An active subscription — one customer paying for one Plan over time.
/// Customer is referenced by stripe customer ID + email; we don't require a
/// User record (subscriptions can predate user auth setup).
model Subscription {
  id                   String    @id @default(cuid())
  tenantId             String
  planId               String
  plan                 Plan      @relation(fields: [planId], references: [id])
  // Customer identification — flexible because subscribers may not be
  // platform users. clientId links to existing Client model when applicable.
  clientId             Int? // existing Client model (BMT billing)
  customerEmail        String
  customerName         String?
  // Stripe linkage
  stripeCustomerId     String?
  stripeSubscriptionId String?   @unique
  // Lifecycle
  status               String // "trialing" | "active" | "past_due" | "canceled" | "unpaid" | "incomplete"
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean   @default(false)
  canceledAt           DateTime?
  trialEndsAt          DateTime?
  // Audit
  metadata             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Tier 3 tracking — every active subscription with platformFeePercent > 0
  // gets a ModuleEngagement record for finance reporting.
  engagement           ModuleEngagement?

  @@index([tenantId, status])
  @@index([clientId])
  @@index([customerEmail])
  @@index([status, currentPeriodEnd])
}

/// One-off SKU — merch, prints, books, ticket inventory templates.
/// Distinct from Plan (which is recurring) but lives in the same Commerce module.
model Product {
  id               String    @id @default(cuid())
  tenantId         String
  brand            String
  slug             String
  name             String
  description      String    @db.Text
  priceCents       Int
  currency         String    @default("usd")
  // Inventory — null = unlimited (digital goods, services), int = stock level
  inventoryLevel   Int?
  trackInventory   Boolean   @default(false)
  active           Boolean   @default(true)
  weight           Int? // grams, for shipping calc
  shippable        Boolean   @default(false)
  taxable          Boolean   @default(true)
  imageUrls        String[]
  metadata         Json?
  stripeProductId  String?
  stripePriceId    String?
  platformFeePercent Decimal? @db.Decimal(5, 2)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  orderItems       OrderItem[]

  @@unique([tenantId, slug])
  @@index([tenantId, brand, active])
}

/// One-off order — distinct from Subscription. Single transactional purchase.
model Order {
  id                  String    @id @default(cuid())
  tenantId            String
  // Customer
  clientId            Int?
  customerEmail       String
  customerName        String?
  // Order state
  status              String // "pending" | "paid" | "fulfilled" | "shipped" | "refunded" | "cancelled"
  subtotalCents       Int
  taxCents            Int       @default(0)
  shippingCents       Int       @default(0)
  totalCents          Int
  currency            String    @default("usd")
  // Stripe linkage
  stripeCheckoutId    String?   @unique
  stripePaymentIntentId String? @unique
  // Fulfillment
  shippingAddress     Json?
  fulfilledAt         DateTime?
  shippedAt           DateTime?
  trackingNumber      String?
  // Audit
  metadata            Json?
  notes               String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  items               OrderItem[]

  @@index([tenantId, status])
  @@index([clientId])
  @@index([customerEmail])
  @@index([status, createdAt])
}

/// Line item on an Order — captures the price at time of purchase (Product
/// price may change later; OrderItem.priceCents is immutable history).
model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  quantity        Int
  priceCents      Int // captured at purchase time
  totalCents      Int // priceCents * quantity
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

// ─── Block 3 · Finance Module ────────────────────────────────
// Tier 3 module engagement tracking + Studio C bucket-hour math +
// per-entity P&L. Hooks into Subscription (Block 1) for auto-recording.

/// Per-module pricing rules. One row per module (commerce, booking, etc.)
/// per pricing tier. Used to derive the platformFeePercent on a Plan.
model ModuleLicenseProfile {
  id                  String   @id @default(cuid())
  module              String // "commerce" | "booking" | "broadcast" | "social" | etc.
  tier                String // "starter" | "standard" | "enterprise"
  monthlyMinimumCents Int      @default(0) // floor charge regardless of revenue
  feePercent          Decimal  @db.Decimal(5, 2) // 15-30 typical
  scope               String   @db.Text // human-readable description of what's included
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([module, tier])
  @@index([module, active])
}

/// A recurring vendor service powered by MBT modules. Created automatically
/// when a Subscription with platformFeePercent > 0 activates. The vendor
/// (Tuthill, Records, Radio) sells to a customer; MBT invoices the vendor
/// for the platform fee. This is the bookkeeping record.
model ModuleEngagement {
  id              String        @id @default(cuid())
  vendorTenantId  String // who sells the service ("tuthill", "records", "radio")
  customerEmail   String // who pays the vendor (the realtor, the artist, etc.)
  subscriptionId  String?       @unique
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  modules         String[] // ["commerce", "social", "broadcast"] — which MBT modules power this
  // Revenue split
  monthlyRevenueCents Int // what the vendor charges the customer
  platformFeePercent  Decimal @db.Decimal(5, 2) // copied from Plan at engagement creation
  // Lifecycle
  status          String        @default("active") // "active" | "paused" | "ended"
  startedAt       DateTime      @default(now())
  endedAt         DateTime?
  // Audit
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([vendorTenantId, status])
  @@index([status, startedAt])
  @@index([customerEmail])
}

/// Studio C bucket-hour ledger. MBT buys buckets of fungible Studio C hours
/// from Tuthill Design LLC. Consuming entities (MBT, Big Muddy Natchez,
/// Big Muddy Touring) draw down per project. Refilled monthly.
model RetainerHour {
  id                String   @id @default(cuid())
  // The bucket
  bucketMonth       String // "2026-04" — granular to month
  // The work
  consumingEntityId String // "mbt" | "big-muddy-natchez" | "big-muddy-touring" | external client tenant
  projectRef        String? // free-form project tag — links to project queue, github issue, etc.
  hoursWorked       Decimal  @db.Decimal(7, 2)
  hourlyRateCents   Int      @default(5000) // bucket rate, $50/hr default
  totalCents        Int // hoursWorked * hourlyRateCents
  // Metadata
  workedBy          String? // optional person name (Elijah, Miles) for transparency
  workType          String? // "platform" | "photo" | "video" | "design" | "other"
  workedDate        DateTime
  notes             String?  @db.Text
  // Source
  invoiceRef        String? // links back to the bucket-purchase invoice
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([bucketMonth, consumingEntityId])
  @@index([consumingEntityId, workedDate])
}

// ─── Block 5 · Coordination Layer Event Bus ──────────────────
// Renamed from "Event" to "BusEvent" to avoid collision with existing
// Event model (Blues Room shows). Backed by PgBoss for delivery; these
// models are the audit/observability layer.

/// Audit log of every event published. PgBoss handles the actual queueing
/// and locking; these rows survive after the queue job is archived.
model BusEvent {
  id            String   @id @default(cuid())
  type          String // "directory.entry.created", "subscription.activated"
  tenantId      String // multi-tenant isolation key (validated against config/tenants.ts)
  payload       Json
  source        String // module that published it
  correlationId String? // ties together related events from one user action
  publishedAt   DateTime @default(now())
  jobId         String? // pgboss job id for trace

  deliveries    EventDelivery[]

  @@index([type, tenantId, publishedAt])
  @@index([tenantId, publishedAt])
}

/// Registered handlers — one row per (eventType, module). enabled=false
/// disables the handler without a code deploy.
model EventHandler {
  id          String   @id @default(cuid())
  name        String   @unique // "social.publishDirectoryEntry"
  eventType   String // "directory.entry.created"
  module      String // "social"
  tenantScope String   @default("own") // "own" | "all" | comma-sep tenant ids
  enabled     Boolean  @default(true)
  maxRetries  Int      @default(5)
  timeoutMs   Int      @default(30000)
  createdAt   DateTime @default(now())

  deliveries  EventDelivery[]

  @@index([eventType, enabled])
}

/// Per-attempt delivery log. status="dead" = retry exhausted; surfaced in
/// /admin/events/dead-letter for manual replay or investigation.
model EventDelivery {
  id          String       @id @default(cuid())
  eventId     String
  event       BusEvent     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  handlerId   String
  handler     EventHandler @relation(fields: [handlerId], references: [id])
  status      String // "pending" | "running" | "succeeded" | "failed" | "dead" | "blocked"
  attempt     Int          @default(0)
  lastError   String?      @db.Text
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())

  @@index([status, createdAt])
  @@index([eventId])
}

// ─── Block 4 · Broadcast Module ──────────────────────────────
// Podcast publishing + TikTok Live orchestration + clip extraction.

/// A podcast show — one row per show (Big Muddy Highlights, Delta Dawn,
/// Blues Room Live, etc.). Submitted to Buzzsprout once for distribution
/// to Spotify, Apple, YouTube Music.
model PodcastShow {
  id           String           @id @default(cuid())
  slug         String           @unique
  title        String
  description  String           @db.Text
  brand        String // "radio" | "magazine" | "inn" — drives voice routing
  authorName   String
  authorEmail  String
  artworkUrl   String // 3000x3000 required by Apple
  category     String // Apple iTunes category
  language     String           @default("en-us")
  explicit     Boolean          @default(false)
  buzzsproutId String? // null until first publish
  episodes     PodcastEpisode[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([brand])
}

/// A podcast episode — heavy fields (audio, duration, size) live here;
/// editorial fields (title, description, show notes) live in Sanity and
/// sync via webhook.
model PodcastEpisode {
  id                  String      @id @default(cuid())
  showId              String
  show                PodcastShow @relation(fields: [showId], references: [id])
  episodeNumber       Int
  seasonNumber        Int?
  title               String
  description         String      @db.Text
  audioUrl            String // GCS canonical URL
  audioDurationSec    Int
  audioSizeBytes      Int
  audioMimeType       String      @default("audio/mpeg")
  publishedAt         DateTime?
  buzzsproutEpisodeId String?
  sourceClipIds       String[] // optional: clips this episode was assembled from
  transcript          String?     @db.Text
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@unique([showId, episodeNumber, seasonNumber])
  @@index([showId, publishedAt])
}

/// A scheduled or live broadcast. Mac mini OBS handles encoding; this row
/// is the platform-side coordination record.
model LiveBroadcast {
  id               String          @id @default(cuid())
  brand            String // "radio" | "magazine"
  title            String
  description      String          @db.Text
  scheduledStart   DateTime
  scheduledEnd     DateTime
  actualStart      DateTime?
  actualEnd        DateTime?
  platform         String          @default("tiktok_live")
  obsScene         String? // OBS scene name to auto-load
  cameras          Json // [{name, rtmpKey, position}]
  thumbnailUrl     String?
  status           String          @default("scheduled") // scheduled|live|ended|aborted
  hostUserIds      String[]
  associatedShowId String? // links to PodcastShow when clips republish
  clips            BroadcastClip[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([brand, scheduledStart])
  @@index([status])
}

/// An extracted clip from a LiveBroadcast. AI-enriched (caption, voice
/// profile), then republished to IG Reels and/or appended to a podcast.
model BroadcastClip {
  id           String        @id @default(cuid())
  broadcastId  String
  broadcast    LiveBroadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  sequence     Int
  startSec     Int
  endSec       Int
  videoUrl     String // GCS
  thumbnailUrl String?
  caption      String?       @db.Text
  voiceProfile String? // "radio-music" | "magazine-hospitality"
  status       String        @default("raw") // raw|enriched|published|rejected
  publishedTo  Json          @default("[]") // [{platform, postId, url, at}]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([broadcastId, sequence])
  @@index([status, createdAt])
}

// ─── Block 2 · Booking Module ────────────────────────────────
// Ticket inventory + private event quote workflow + service appointments.
// Inn rooms continue to use Cloudbeds (existing); these models cover
// everything else (tickets, quotes, service slots).

/// A bookable resource — Blues Room ticket inventory for a specific show,
/// a service appointment slot, an event-day rental window. Distinct from
/// Subscription (recurring) and Product (off-shelf SKU).
model Resource {
  id              String        @id @default(cuid())
  tenantId        String
  brand           String
  type            String // "blues_room_ticket" | "service_slot" | "event_rental"
  name            String
  description     String?       @db.Text
  // Time-bounded resources (a show, a window)
  startsAt        DateTime?
  endsAt          DateTime?
  // Capacity
  totalCapacity   Int
  reservedCount   Int           @default(0)
  // Pricing
  priceCents      Int
  currency        String        @default("usd")
  // Lifecycle
  active          Boolean       @default(true)
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  bookings        Booking[]
  tickets         Ticket[]

  @@index([tenantId, brand, active])
  @@index([type, startsAt])
}

/// A booking — confirmed seat/slot/window. For tickets, see Ticket model;
/// for general bookings (event rentals, service appointments), use this.
model Booking {
  id              String    @id @default(cuid())
  tenantId        String
  resourceId      String
  resource        Resource  @relation(fields: [resourceId], references: [id])
  // Customer
  customerEmail   String
  customerName    String?
  customerPhone   String?
  // Status
  status          String // "held" | "confirmed" | "checked_in" | "no_show" | "cancelled"
  quantity        Int       @default(1)
  // Payment
  totalCents      Int
  depositCents    Int       @default(0) // for events with deposit + final payment
  stripeCheckoutId String?  @unique
  // Lifecycle
  heldUntil       DateTime? // if held but not confirmed, expires here
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  notes           String?   @db.Text
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([resourceId, status])
  @@index([customerEmail])
}

/// A single Blues Room ticket — emitted with a QR code for door-scan
/// validation. Multiple Tickets can attach to one Booking (group purchase).
model Ticket {
  id              String   @id @default(cuid())
  resourceId      String
  resource        Resource @relation(fields: [resourceId], references: [id])
  bookingId       String? // null for walk-up tickets
  ticketCode      String   @unique // QR-encoded
  customerEmail   String
  customerName    String?
  status          String // "active" | "used" | "refunded" | "void"
  scannedAt       DateTime?
  scannedBy       String? // door staff name
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([resourceId, status])
  @@index([customerEmail])
  @@index([status, scannedAt])
}

/// A private-event quote request — customer submits inquiry, Tracy reviews,
/// quote is generated, customer pays deposit, event becomes a Booking.
model QuoteRequest {
  id              String    @id @default(cuid())
  tenantId        String
  brand           String
  // Customer
  customerEmail   String
  customerName    String
  customerPhone   String?
  // Event details
  eventType       String // "wedding" | "retreat" | "dinner" | "corporate" | "other"
  proposedDate    DateTime?
  flexibleDates   Boolean   @default(false)
  guestCount      Int?
  description     String    @db.Text
  budget          String? // "$5K-$10K" — string for ranges
  // Workflow
  status          String    @default("submitted") // "submitted" | "reviewing" | "quoted" | "deposit_pending" | "confirmed" | "declined" | "abandoned"
  quoteCents      Int? // populated when Tracy generates the quote
  quoteValidUntil DateTime?
  depositCents    Int? // typically 30-50% of quote
  // Deposit payment
  depositPaidAt   DateTime?
  stripePaymentIntentId String? @unique
  // Conversion
  bookingId       String? // populated when quote → confirmed booking
  // Notes
  internalNotes   String?   @db.Text
  customerNotes   String?   @db.Text
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([status, createdAt])
  @@index([customerEmail])
}

/// ─── BROADCAST MODULE — Mac mini agent instruction queue ───
///
/// Persistent queue for instructions sent from the MBT server to the
/// broadcast agent running on the Mac mini. Previously this was in-memory
/// module state (broken in Vercel's serverless multi-instance env — flagged
/// CRITICAL #2 in the 2026-04-19 Gemini review).
model BroadcastAgentInstruction {
  id            String    @id @default(cuid())
  type          String // "obs.scene_change" | "ffmpeg.extract_clip" | "gcs.upload" | custom
  payload       Json
  status        String    @default("pending") // "pending" | "claimed" | "acked" | "failed"
  priority      Int       @default(0) // higher = earlier
  claimedAt     DateTime? // set when the agent dequeues it
  ackedAt       DateTime? // set when agent posts back to /ack
  result        Json? // result payload from agent (if any)
  error         String? // error message if agent failed
  issuedBy      String? // operator email / "system" / cron name
  issuedAt      DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, priority, issuedAt])
  @@index([status, claimedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// STUDIO C PRODUCTION OPS MODULE — Phase 1 (2026-05-01)
// ─────────────────────────────────────────────────────────────────────────────
// Production operations spine for Studio C: clients, brand kits, recurring shows,
// episodes, jobs (work orders), ingest, approvals, version history, QC, rights,
// retention, and deliverables.
//
// Naming: prefixed `Studio*` where existing models would conflict (Show, Episode,
// Job all exist with different semantics elsewhere in this schema). Otherwise
// neutral names where there's no collision.
//
// Storage split rule:
// - Sanity = canonical content humans edit (Brand, BrandKit, StudioShow, StudioEpisode meta)
// - Postgres (these models) = operational state with state machines + frequent queries
//
// Relations to existing models:
// - Brand (existing, minimal: slug, name) → extended with BrandKit (1:1) and StudioShows
// - User (existing) → assigned to StudioJob, signs StudioApproval
//
// Phase 1 = schema only. No migration is run by this PR. Migration plan is in
// docs/studio-c/workflow-synthesis-2026-05-01.md.
// ─────────────────────────────────────────────────────────────────────────────

/// Production client. The entity paying for the work.
/// Distinct from the existing `Client` model (Deep South Directory directory
/// listings with tier=front-porch/route). A ProductionClient is who Studio C
/// invoices.
model ProductionClient {
  id              String        @id @default(cuid())
  /// Tenant scope. Most clients today are 'mbt' (Measurably Better Things)
  /// with internal brands. External clients can sit under 'studio-c' tenant.
  tenantId        String        @default("mbt") // see apps/web/config/tenants.ts
  name            String
  slug            String        @unique
  /// Internal MBT brand (Big Muddy, Bearsville, etc.) vs External (paid client).
  kind            String        @default("internal") // internal | external
  /// Primary contact email for billing and approvals.
  contactEmail    String?
  contactName     String?
  /// The legal entity invoiced. Empty for internal MBT brands.
  billingEntity   String?
  /// Notes (engagement scope, special terms, etc.).
  notes           String?       @db.Text
  brands          Brand[]
  jobs            StudioJob[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId])
  @@index([kind])
}

/// Machine-readable brand kit. Drives downstream NLE template generation
/// (.mogrt for Premiere, .drfx for Resolve), social templates, and chat voice
/// routing.
///
/// The Sanity `brandKit` doc is the human-edited source of truth; this Postgres
/// row is a denormalized cache for fast querying + foreign-key relations.
model BrandKit {
  id              String        @id @default(cuid())
  brandId         String        @unique
  brand           Brand         @relation(fields: [brandId], references: [id])
  /// Sanity document ID — the human-edited canonical version.
  sanityDocId     String?
  /// Versioned. Bump when any field changes; downstream templates reference a
  /// specific version so re-renders are reproducible.
  version         Int           @default(1)
  /// Logos: { light, dark, mono } — URLs pointing at GCS / R2.
  logos           Json
  /// Fonts: array of { name, url, weights, role } where role = display | body | mono.
  fonts           Json
  /// Color palette: array of { hex, name, role } where role = primary | secondary | accent | bg | ink.
  /// Locked at 5 colors max per the onboarding spec.
  palette         Json
  /// Tone of voice + do/don't list. Plain text or structured.
  voice           String?       @db.Text
  /// Lower-third template reference (Sanity asset ID or path).
  lowerThirdRef   String?
  /// Intro / outro sting references.
  introStingRef   String?
  outroStingRef   String?
  /// Social templates per platform. { instagram, tiktok, youtube_short, etc. }
  socialTemplates Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([brandId])
}

/// Recurring show. The container for episodes.
/// Examples: "The Big Muddy Podcast", "Ask Me Anything", "Inverted Intelligence".
/// Maps loosely to the existing PodcastShow model on the publishing side, but
/// represents the production concept (multicam setup, recurring cadence).
model StudioShow {
  id              String           @id @default(cuid())
  brandId         String
  brand           Brand            @relation(fields: [brandId], references: [id])
  slug            String           @unique
  title           String
  description     String?          @db.Text
  /// Track A (high-volume podcasts) or Track B (cinematic / commercial).
  track           String           @default("A") // A | B
  /// Cadence: weekly | biweekly | monthly | irregular.
  cadence         String           @default("weekly")
  /// Studio location: woodstock (Bearsville, BMD ecosystem) | natchez (Sony ecosystem).
  primaryStudio   String           @default("woodstock") // woodstock | natchez
  /// Approval tier for episodes that match this show's template.
  /// A = Chase only. B = Elijah/Miles can ship. C = automated.
  approvalTier    String           @default("B") // A | B | C
  /// Default deliverable specs (frame rate, color space, audio LUFS, exports).
  /// Drives the technical specs bible.
  technicalSpecs  Json?
  episodes        StudioEpisode[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([brandId])
  @@index([track])
  @@index([approvalTier])
}

/// Individual episode within a recurring show.
model StudioEpisode {
  id              String        @id @default(cuid())
  showId          String
  show            StudioShow    @relation(fields: [showId], references: [id])
  /// Sequential within the show. e.g., 001, 002, 003.
  episodeNumber   Int
  slug            String        @unique
  title           String
  /// Planned shoot date. Null if not yet scheduled.
  shootDate       DateTime?
  /// Guest list, topic, prep notes — markdown/text.
  prepNotes       String?       @db.Text
  /// Status: planned | shot | in_post | published | archived
  status          String        @default("planned")
  jobs            StudioJob[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([showId, episodeNumber])
  @@index([status])
  @@index([shootDate])
}

/// Studio C work order. The canonical job ticket. Every shoot, edit, conform,
/// or deliverable runs through one of these. State machine in
/// apps/web/lib/studio-c/state-machines/job-lifecycle.ts.
model StudioJob {
  id                 String              @id @default(cuid())
  /// Optional — recurring show episodes link here. One-off commercial work
  /// has no episodeId; just clientId + title.
  episodeId          String?
  episode            StudioEpisode?      @relation(fields: [episodeId], references: [id])
  /// Required — who's paying.
  clientId           String
  client             ProductionClient    @relation(fields: [clientId], references: [id])
  title              String
  /// Track A (podcast pipeline) or B (cinematic / commercial).
  track              String              @default("A") // A | B
  /// State machine. See job-lifecycle.ts for valid transitions.
  state              String              @default("intake") // intake | prep | shooting | ingesting | editing | internal_review | chase_review | revisions | conforming | delivered | archived | cancelled | on_hold
  /// Approval tier — drives who can advance the state machine on review steps.
  approvalTier       String              @default("B") // A | B | C
  /// Owner — typically Miles (production) or Elijah (chief of staff).
  ownerId            String?
  owner              User?               @relation("StudioJobOwner", fields: [ownerId], references: [id])
  /// Studio executing the work.
  studio             String              @default("woodstock") // woodstock | natchez
  /// Brand the job is FOR. Allows joining to BrandKit for template generation.
  brandId            String?
  brand              Brand?              @relation("StudioJobBrand", fields: [brandId], references: [id])
  /// Delivery deadline.
  dueAt              DateTime?
  /// SLA timestamps for tier-based escalation.
  /// Set when state enters internal_review. Auto-escalation if exceeded.
  reviewSlaExpiresAt DateTime?
  /// Free-form notes.
  notes              String?             @db.Text
  ingestRecords      IngestRecord[]
  approvals          StudioApproval[]
  versions           VersionHistory[]
  qcChecks           QcChecklist[]
  rights             RightsRecord[]
  deliverables       Deliverable[]
  retention          RetentionStatus?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([clientId])
  @@index([state])
  @@index([approvalTier])
  @@index([ownerId])
  @@index([episodeId])
  @@index([dueAt])
}

/// Card offload log with checksums. Religious about this — every automation
/// downstream depends on the integrity of the ingest record. One row per card
/// (or per logical batch) per shoot day.
model IngestRecord {
  id                String        @id @default(cuid())
  jobId             String
  job               StudioJob     @relation(fields: [jobId], references: [id])
  /// Camera identifier: A, B, C (or A1, A2 for unit splits).
  camera            String
  /// Card identifier — usually the card label from set.
  cardLabel         String
  /// Filesystem path or LucidLink URI where files were offloaded to.
  destinationPath   String
  /// xxhash or md5 of the source card. Compared after copy completes.
  sourceChecksum    String?
  /// Checksum after copy. Must match sourceChecksum or the row is failed.
  destChecksum      String?
  checksumVerified  Boolean       @default(false)
  fileCount         Int           @default(0)
  byteCount         BigInt        @default(0)
  /// Was an ISO backup recorded for this shoot day? Cheap insurance against
  /// line cut failure. Per the synthesis doc: every podcast records ISOs.
  isoBackupPresent  Boolean       @default(false)
  ingestedAt        DateTime      @default(now())
  ingestedById      String?
  ingestedBy        User?         @relation(fields: [ingestedById], references: [id])
  notes             String?       @db.Text

  @@index([jobId])
  @@index([camera])
  @@index([checksumVerified])
}

/// Approval record. One row per approval gate the job passes through.
/// Tiered: A (Chase), B (Elijah/Miles), C (automated under approved show rules).
model StudioApproval {
  id                String        @id @default(cuid())
  jobId             String
  job               StudioJob     @relation(fields: [jobId], references: [id])
  /// What stage of the lifecycle this approval is for.
  /// Examples: prep_approval | rough_cut | client_review | final_release
  gate              String
  /// A | B | C — the tier required to sign off on this gate.
  requiredTier      String
  /// pending | approved | revisions_requested | rejected
  status            String        @default("pending")
  /// Who signed off. Null if status is pending.
  signedById        String?
  signedBy          User?         @relation(fields: [signedById], references: [id])
  signedAt          DateTime?
  /// SLA deadline for this approval. Auto-escalation rules in Phase 2.
  slaExpiresAt      DateTime?
  notes             String?       @db.Text
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([jobId])
  @@index([status])
  @@index([requiredTier])
  @@index([slaExpiresAt])
}

/// Version history. Tracks v01_editor → v05_final progression for every
/// deliverable on a job. No "final_final_REAL" — every version has a numbered
/// label and a clear stage.
model VersionHistory {
  id                String        @id @default(cuid())
  jobId             String
  job               StudioJob     @relation(fields: [jobId], references: [id])
  /// Sequential version number (1, 2, 3...).
  versionNumber     Int
  /// Stage: editor | internal | chase_notes | client_review | final
  stage             String
  /// Storage path or LucidLink URI for this version's master file.
  storagePath       String
  /// Notes on what changed in this version.
  changeNotes       String?       @db.Text
  /// Who produced this version.
  authorId          String?
  author            User?         @relation(fields: [authorId], references: [id])
  createdAt         DateTime      @default(now())

  @@unique([jobId, versionNumber])
  @@index([stage])
}

/// QC checklist instance — one per deliverable, filled out before sign-off.
/// Enforces "definition of done" so Chase doesn't become the QC robot.
model QcChecklist {
  id                String        @id @default(cuid())
  jobId             String
  job               StudioJob     @relation(fields: [jobId], references: [id])
  /// Which deliverable this QC is for. Null if checking the master itself.
  deliverableId     String?
  deliverable       Deliverable?  @relation(fields: [deliverableId], references: [id])
  /// JSON object: { audio_lufs_pass: true, captions_present: true, brand_kit_applied: true, names_spelled_correctly: true, ... }
  /// Schema for items lives in apps/web/lib/studio-c/qc-checklist-schema.ts (Phase 2).
  checks            Json
  /// Overall pass/fail. Computed from checks. Set explicitly when reviewer signs off.
  passed            Boolean       @default(false)
  /// Reviewer who signed off (or flagged failure).
  reviewerId        String?
  reviewer          User?         @relation(fields: [reviewerId], references: [id])
  reviewedAt        DateTime?
  notes             String?       @db.Text
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([jobId])
  @@index([passed])
}

/// Rights / releases / music licensing tied to a job.
/// Lives next to the project record, not in email.
model RightsRecord {
  id                String        @id @default(cuid())
  jobId             String
  job               StudioJob     @relation(fields: [jobId], references: [id])
  /// Type: model_release | location_release | music_license | sync_license | guest_appearance | other
  kind              String
  /// Subject — name of person, location, song, etc.
  subject           String
  /// Storage path to scanned/signed document.
  documentPath      String?
  /// Usage windows / term constraints. e.g., "perpetual" | "1 year, broadcast only".
  termsSummary      String?       @db.Text
  /// Effective + expiration dates. Null expiration = perpetual.
  effectiveAt       DateTime?
  expiresAt         DateTime?
  /// Has the document actually been collected? Pending = we haven't gotten it.
  status            String        @default("pending") // pending | collected | expired | invalid
  notes             String?       @db.Text
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([jobId])
  @@index([kind])
  @@index([status])
  @@index([expiresAt])
}

/// Retention status. Computed from delivery date + tier policy, but stored
/// for audit. Drives the auto-tier-to-cold-storage and auto-purge automations
/// in Phase 2.
model RetentionStatus {
  id                String        @id @default(cuid())
  jobId             String        @unique
  job               StudioJob     @relation(fields: [jobId], references: [id])
  /// Current tier: active | delivered_30d | cold_90d | minimal_1yr | forever | purged
  tier              String        @default("active")
  /// When the job was delivered. Drives all downstream tier transitions.
  deliveredAt       DateTime?
  /// Next tier transition date (computed).
  nextTransitionAt  DateTime?
  /// Last automated tier change. Manual overrides bypass the automation.
  lastTransitionedAt DateTime?
  /// Override flag — Chase or Elijah can extend retention.
  manualOverride    Boolean       @default(false)
  notes             String?       @db.Text
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([tier])
  @@index([nextTransitionAt])
}

/// Final output artifact — the thing the client gets.
/// One job can have many deliverables: a 30-min episode + 5 social cuts
/// + a thumbnail + chapter markers all hang off the same StudioJob.
model Deliverable {
  id                String        @id @default(cuid())
  jobId             String
  job               StudioJob     @relation(fields: [jobId], references: [id])
  /// Type: master | social_clip | thumbnail | transcript | chapters | sponsor_read | bts | other
  kind              String
  title             String
  /// Storage path or URL of the final exported file.
  storagePath       String
  /// Spec: { frameRate, resolution, audioLufs, container, codec }
  spec              Json?
  /// Where it was delivered to. e.g., "youtube" | "spotify" | "client_dropbox" | "frame_io_review"
  destination       String?
  /// External ID at destination (e.g., YouTube video ID, Postiz post ID).
  destinationRef    String?
  /// Has it been delivered? false = exported but not yet sent.
  delivered         Boolean       @default(false)
  deliveredAt       DateTime?
  qcChecks          QcChecklist[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([jobId])
  @@index([kind])
  @@index([delivered])
}
