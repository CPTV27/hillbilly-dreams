// packages/database/prisma/schema.prisma

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // Use connection pooling URL for serverless (Next.js API routes, Firebase Functions)
  directUrl  = env("DIRECT_DATABASE_URL")
  extensions = [vector]
}

// ─────────────────────────────────────────────────────────────
// NATCHEZ PROTOCOL — canonical intelligence + economy (Sovereign Engine)
// Core models: User (sovereignTier, credits, isVetted, guild graph), CreditLedger,
// LoreEntry (namespace, sourceUrl, confidenceScore), Entity (power map), Venue,
// Performance (+ MediaAsset). Legacy BMT/DSD tables remain for production routes;
// new work should prefer these primitives on fresh DBs (e.g. hillbilly_sovereign).
// ─────────────────────────────────────────────────────────────

enum SovereignMembershipTier {
  FREE
  PRO
  NETWORK
  INTEL
}

// ─────────────────────────────────────────────────────────────
// MAGAZINE
// ─────────────────────────────────────────────────────────────

model Article {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  category    String    // city-guide | feature | photo-essay | interview | food-drink | music
  city        String?   // memphis | clarksdale | natchez | new-orleans | vicksburg | etc.
  author      String    @default("Big Muddy Magazine")
  status      String    @default("draft")     // draft | review | published
  excerpt     String?
  body        String?   @db.Text
  heroImage   String?   // Cloudflare R2 URL
  readTime    String?   // e.g. "6 min read"
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // ── S2PX Bridge Provenance ──
  sourceSystem    String?   // "s2px" | null (manual)
  sourceProjectId String?   // S2PX UPID e.g. "S2P-042-2025"
  sourcePayload   String?   @db.Text  // Sanitized JSON audit trail
  sourceSyncedAt  DateTime?

  // ── Deep South Directory Link ──
  // SOFT FK: references db-media Client.id — no @relation constraint (cross-sovereign)
  clientId    Int?

  @@index([status, publishedAt])
  @@index([category])
  @@index([city])
  @@index([clientId])
  @@index([sourceSystem, sourceProjectId])
}

// ─────────────────────────────────────────────────────────────
// RADIO
// ─────────────────────────────────────────────────────────────

model Playlist {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  trackCount  Int      @default(0)
  spotifyUrl  String?  // spotify:playlist:xxx or https://open.spotify.com/playlist/xxx
  coverImage  String?  // Cloudflare R2 URL
  status      String   @default("active")  // active | archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model Event {
  id          Int      @id @default(autoincrement())
  name        String
  date        DateTime
  time        String?              // e.g. "7:00 PM CT" — stored separately for display flexibility
  artist      String?
  description String?
  price       String?              // e.g. "$25" or "Free" — string to allow flexibility
  capacity    Int      @default(50)
  status      String   @default("upcoming")  // upcoming | sold-out | cancelled | completed
  stream      Boolean  @default(false)       // whether this event will be livestreamed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date, status])
}

// ─────────────────────────────────────────────────────────────
// NEWSLETTER
// ─────────────────────────────────────────────────────────────

model NewsletterIssue {
  id          Int      @id @default(autoincrement())
  issueNumber Int      @unique
  subject     String
  storyTitle  String?
  storyBody   String?  @db.Text
  playlist    String?  // Playlist name or Spotify URL
  reason      String?  // "Why You Should Go" section
  quickHits   String?  @db.Text  // Comma-separated or JSON array of bullets
  status      String   @default("draft")  // draft | scheduled | sent
  sendDate    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, sendDate])
}

// ─────────────────────────────────────────────────────────────
// CRM / CONTACTS
// ─────────────────────────────────────────────────────────────

model Contact {
  id           Int       @id @default(autoincrement())
  name         String
  role         String?
  organization String?
  email        String?
  phone        String?
  category     String?   // artist | vendor | media | partner | guest | team
  notes        String?   @db.Text
  lastContact  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([category])
  @@index([email])
}

// ─────────────────────────────────────────────────────────────
// GROWTH — Sovereign Sales Engine (scouting & intel tiers)
// ─────────────────────────────────────────────────────────────

/// High-value prospect for Network ($99) / Intel ($300) outreach — not a substitute for CRM consent.
model Lead {
  id                 String    @id @default(cuid())
  name               String
  industry           String
  /// Subjective 1–10 influence / wallet heuristic from scout scoring
  perceivedPower     Int       @default(5)
  lastInteraction    DateTime?
  /// JSONB: graph edges (entity IDs, roles, notes) for follow-up
  socialGraphNodes   Json      @default("{}")
  email              String?
  phone              String?
  source             String    @default("scout") // scout | manual | import
  notes              String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([industry])
  @@index([perceivedPower])
  @@index([source])
}

// ─────────────────────────────────────────────────────────────
// DASHBOARD METRICS
// ─────────────────────────────────────────────────────────────

model Metric {
  id        Int      @id @default(autoincrement())
  key       String   @unique  // e.g. "newsletter_subscribers", "inn_occupancy_rate", "spotify_followers"
  value     Float
  target    Float?
  label     String?           // Display label: "Newsletter Subscribers"
  unit      String?           // "subscribers", "%", "followers", etc.
  source    String?           // "beehiiv" | "cloudbeds" | "spotify" | "manual"
  updatedAt DateTime @updatedAt

  @@index([key])
}

// Append-only time-series companion to Metric. Metric stores the latest value;
// MetricSnapshot stores the full history for trend charts and client reports.
model MetricSnapshot {
  id         Int      @id @default(autoincrement())
  metricKey  String                                // Matches Metric.key
  value      Float
  source     String?                               // "beehiiv" | "cloudbeds" | "census" | "bls" | "manual"
  recordedAt DateTime @default(now())

  @@index([metricKey, recordedAt])
  @@index([recordedAt])
}

// ─────────────────────────────────────────────────────────────
// SOVEREIGNTY NOTE: Media/Directory models below (Client through
// DirectoryBusiness) are pending migration to packages/db-media.
// Article.clientId and SocialAccount.clientId are now SOFT FKs.
// Decomposed: 2026-03-24 — Phase C (AG)
// ─────────────────────────────────────────────────────────────
// CLIENT MANAGEMENT (Media-as-a-Service)
// ─────────────────────────────────────────────────────────────

model BridgeClient {
  id          Int      @id @default(autoincrement())
  name        String                    // "Scan2Plan", "FutureClient_X"
  apiKey      String   @unique          // Public identifier (cuid)
  apiSecret   String                    // HMAC-SHA256 secret (64-char hex, hashed at rest)
  status      String   @default("active") // active | suspended
  allowedCategories String[]            // Which article categories this client can create
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastSyncAt  DateTime?

  @@index([apiKey])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// SOCIAL MEDIA
// ─────────────────────────────────────────────────────────────

model SocialAccount {
  id          Int      @id @default(autoincrement())
  platform    String   // facebook | instagram | google_business | twitter | tiktok | threads | bluesky | linkedin
  handle      String   // @outsiderecon, @bigmuddymedia, etc.
  brand       String   @default("bigmuddy") // bigmuddy | radio | magazine | touring | economics
  status      String   @default("active")   // active | paused | disconnected
  notes       String?
  // SOFT FK: references db-media Client.id — no @relation constraint (cross-sovereign)
  clientId    Int?
  // ── OAuth / Publishing Tokens ──
  platformId    String?  // Platform-specific page/account ID (e.g. FB Page ID, GBP location ID)
  accessToken   String?  @db.Text  // OAuth access token (encrypted at rest via GCP)
  refreshToken  String?  @db.Text  // OAuth refresh token
  tokenExpiry   DateTime?          // When the access token expires
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       SocialPost[]

  @@unique([platform, handle])
  @@index([brand])
  @@index([status])
}

model SocialPost {
  id          Int       @id @default(autoincrement())
  accountId   Int
  account     SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  content     String    @db.Text           // Post body / caption
  mediaUrls   String[]                     // GCS image/video URLs
  postUrl     String?                      // URL after publishing (paste back)
  status      String    @default("draft")  // draft | ready | published | failed
  scheduledAt DateTime?                    // When to publish (null = no schedule)
  publishedAt DateTime?                    // When actually published
  sourceType  String?                      // article | newsletter | event | economics | manual
  sourceId    String?                      // Reference to source content ID
  tags        String[]                     // hashtags, topics
  visibility  String    @default("draft")  // draft | internal | public — controls AI assistant access
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([accountId, status])
  @@index([status, scheduledAt])
  @@index([sourceType, sourceId])
  @@index([visibility])
}

// ─────────────────────────────────────────────────────────────
// CLIENT MANAGEMENT (Media-as-a-Service)
// ─────────────────────────────────────────────────────────────

model Client {
  id               Int       @id @default(autoincrement())
  name             String
  slug             String    @unique
  tier             String    @default("front-porch") // front-porch | route | river-room | blues-room
  businessType     String    // restaurant | venue | hotel | shop | tour | service | other
  city             String
  state            String    @default("MS")
  address          String?
  phone            String?
  email            String?
  website          String?
  description      String?   @db.Text
  voiceProfile     Json?     // AI-generated brand voice document
  platforms        String[]  // which social platforms they're on
  gbpPlaceId       String?   // Google Business Profile place ID
  gbpUrl           String?   // Google Maps URL
  stripeCustomerId String?
  logoUrl          String?
  heroImageUrl     String?
  stripeConnectId  String?   // Stripe Connect account ID (acct_xxx)
  connectStatus    String?   // "pending" | "active" | "restricted" | "disabled"
  contactName      String?   // Primary contact person
  contactEmail     String?
  contactPhone     String?
  notes            String?   @db.Text
  status           String    @default("onboarding") // onboarding | active | paused | churned
  onboardedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // SOVEREIGNTY NOTE: SocialAccount[] and Article[] back-references REMOVED (2026-03-24)
  // These models reference Client via soft FK (clientId int, no @relation).
  reviews          Review[]
  calendars        ContentCalendar[]
  reports          Report[]
  invoices         Invoice[]
  integrations     ClientIntegration[]
  draftBusinesses  DraftBusiness[]

  @@index([city])
  @@index([tier, status])
  @@index([status])
}

model Review {
  id             Int       @id @default(autoincrement())
  clientId       Int
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform       String    // google | yelp | tripadvisor | facebook
  externalId     String    @unique
  author         String
  rating         Int       // 1-5
  text           String?   @db.Text
  response       String?   @db.Text   // Our drafted response
  responseStatus String    @default("pending") // pending | drafted | approved | posted | skipped
  aiDraft        String?   @db.Text   // AI-generated response draft
  postedAt       DateTime  // When the review was posted
  respondedAt    DateTime? // When we responded
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([clientId, platform])
  @@index([responseStatus])
  @@index([clientId, postedAt])
}

model ContentCalendar {
  id          Int       @id @default(autoincrement())
  clientId    Int
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month       Int       // 1-12
  year        Int
  posts       Json      // Array of planned post objects with content, platform, scheduledDate, status
  status      String    @default("draft") // draft | review | approved | active | completed
  generatedAt DateTime  @default(now())
  approvedAt  DateTime?
  approvedBy  String?
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([clientId, month, year])
  @@index([status])
}

model Report {
  id          Int       @id @default(autoincrement())
  clientId    Int
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month       Int
  year        Int
  data        Json      // Metrics snapshot: posts published, engagement, reviews, etc.
  summary     String?   @db.Text // AI-generated narrative summary
  pdfUrl      String?   // GCS URL for generated PDF
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([clientId, month, year])
}

model Invoice {
  id               Int       @id @default(autoincrement())
  clientId         Int
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  stripeInvoiceId  String?   @unique
  amount           Int       // Amount in cents
  currency         String    @default("usd")
  status           String    @default("draft") // draft | open | paid | void | uncollectible
  periodStart      DateTime
  periodEnd        DateTime
  paidAt           DateTime?
  dueDate          DateTime?
  pdfUrl           String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([clientId, status])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// CLIENT INTEGRATIONS (Pluggable Services)
// ─────────────────────────────────────────────────────────────

model ClientIntegration {
  id           Int       @id @default(autoincrement())
  clientId     Int
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  provider     String    // stripe | square | clover | opentable | resy | cloudbeds | mailchimp | google-analytics | meta-pixel | toast
  status       String    @default("pending") // pending | active | error | disconnected
  accountId    String?   // External account/merchant ID
  accessToken  String?   @db.Text  // Encrypted OAuth token
  refreshToken String?   @db.Text  // Encrypted OAuth refresh token
  expiresAt    DateTime? // Token expiry
  config       Json?     // Provider-specific config (e.g. location IDs, webhook URLs)
  scopes       String[]  // OAuth scopes granted
  displayName  String?   // Human-friendly name ("Anthologist Stripe", "Bobby J's Square")
  lastSyncAt   DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([clientId, provider])
  @@index([provider, status])
  @@index([clientId])
}

// ─────────────────────────────────────────────────────────────
// PUBLISHING PIPELINE
// ─────────────────────────────────────────────────────────────

model PublishJob {
  id          Int       @id @default(autoincrement())
  postId      Int       // Reference to SocialPost
  platform    String    // twitter | instagram | tiktok | bluesky | linkedin | facebook | gbp
  status      String    @default("pending") // pending | processing | published | failed | cancelled
  externalId  String?   // Platform's post ID after publishing
  externalUrl String?   // URL of published post
  error       String?   @db.Text
  attempts    Int       @default(0)
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, scheduledAt])
  @@index([postId])
}

// ─────────────────────────────────────────────────────────────
// SOVEREIGNTY NOTE: All Records/MelodyVault models below are pending
// migration to packages/db-records. Showcase.eventId is already a
// soft FK (no @relation to Event).
// Decomposed: 2026-03-24 — Phase B (AG)
// ─────────────────────────────────────────────────────────────
// TALENT PIPELINE (Rise Up → Showcase → Tour → Promote)
// ─────────────────────────────────────────────────────────────

model Artist {
  id              Int       @id @default(autoincrement())
  name            String
  slug            String    @unique
  genre           String?   // blues | soul | gospel | rock | folk | jazz | hip-hop | country | other
  city            String
  state           String    @default("MS")
  bio             String?   @db.Text
  photoUrl        String?
  socialLinks     Json?     // { instagram, tiktok, spotify, youtube, website, etc }
  source          String    @default("rise-up") // rise-up | scouted | submitted | referral
  status          String    @default("discovered") // discovered | contacted | showcasing | touring | alumni
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  notes           String?   @db.Text
  riseUpCohort    String?   // e.g. "2026-spring"
  discoveredAt    DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // ── External Enrichment IDs ──
  spotifyId             String?   @unique  // Spotify artist ID
  spotifyPopularity     Int?               // 0-100 popularity score
  spotifyFollowers      Int?               // Total Spotify followers
  spotifyMonthlyListeners Int?             // Monthly listener count
  spotifyGenres         String[]           // Spotify genre tags
  musicbrainzId         String?   @unique  // Musicbrainz artist MBID

  showcases       ShowcaseSlot[]
  tourStops       TourStop[]
  tracks          Track[]
  splits          Split[]
  proRegistrations PRORegistration[]
  performances    Performance[]

  @@index([status])
  @@index([city, state])
  @@index([source])
  @@index([genre])
}

// ── MelodyVault: Track Catalog ──
model Track {
  id              Int       @id @default(autoincrement())
  title           String
  slug            String    @unique
  artistId        Int
  artist          Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  albumTitle      String?
  duration        Int?      // seconds
  genre           String?
  mood            String?   // uplifting | melancholic | energetic | chill | intense | warm
  bpm             Int?
  musicalKey      String?   // e.g. "D Major", "A Minor"
  isrc            String?   // International Standard Recording Code
  iswc            String?   // International Standard Musical Work Code
  audioUrl        String?   // GCS or R2 URL to master file
  waveformData    Json?     // pre-computed waveform for UI
  aiAnalysis      Json?     // { genre, mood, bpm, key, syncSuggestions, trendingInsights }
  metadata        Json?     // additional metadata (lyrics, credits, instruments)
  releaseDate     DateTime?
  status          String    @default("uploaded") // uploaded | analyzing | active | archived
  splits          Split[]
  syncSubmissions SyncSubmission[]
  proRegistrations PRORegistration[]
  royalties       RoyaltyPayment[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([artistId])
  @@index([genre, mood])
  @@index([status])
}

// ── MelodyVault: Splits Ledger ──
model Split {
  id          Int       @id @default(autoincrement())
  trackId     Int
  track       Track     @relation(fields: [trackId], references: [id], onDelete: Cascade)
  artistId    Int?
  artist      Artist?   @relation(fields: [artistId], references: [id])
  name        String    // contributor name (may not be a roster artist)
  email       String?
  role        String    // songwriter | producer | performer | engineer | featured
  sharePercent Float    // 0.0 to 100.0
  paypalEmail String?   // for royalty payouts
  status      String    @default("pending") // pending | confirmed | disputed
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([trackId, name, role])
  @@index([trackId])
  @@index([artistId])
}

// ── MelodyVault: Sync Marketplace ──
model SyncOpportunity {
  id            Int       @id @default(autoincrement())
  title         String
  description   String?   @db.Text
  projectType   String    // film | tv | ad | game | podcast | documentary | social
  genre         String?
  mood          String?
  budgetAmount  Int?      // dollars
  budgetType    String?   // buyout | 1-year | 2-year | perpetual
  deadline      DateTime?
  contactEmail  String?
  status        String    @default("open") // open | filled | expired | cancelled
  submissions   SyncSubmission[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, genre])
  @@index([deadline])
}

model SyncSubmission {
  id              Int       @id @default(autoincrement())
  trackId         Int
  track           Track     @relation(fields: [trackId], references: [id], onDelete: Cascade)
  opportunityId   Int
  opportunity     SyncOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  status          String    @default("submitted") // submitted | shortlisted | selected | rejected
  notes           String?   @db.Text
  submittedAt     DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([trackId, opportunityId])
  @@index([opportunityId])
}

// ── MelodyVault: PRO Rights Management ──
model PRORegistration {
  id            Int       @id @default(autoincrement())
  trackId       Int
  track         Track     @relation(fields: [trackId], references: [id], onDelete: Cascade)
  artistId      Int?
  artist        Artist?   @relation(fields: [artistId], references: [id])
  pro           String    // ASCAP | BMI | SESAC
  workId        String?   // W123456789
  registrationStatus String @default("pending") // pending | processing | registered | error
  registeredAt  DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([trackId, pro])
  @@index([registrationStatus])
}

// ── MelodyVault: Royalty Tracking ──
model RoyaltyPayment {
  id          Int       @id @default(autoincrement())
  trackId     Int
  track       Track     @relation(fields: [trackId], references: [id], onDelete: Cascade)
  source      String    // spotify | apple_music | youtube | sync | merch | direct
  period      String    // "2026-Q1" or "2026-03"
  grossAmount Float     // total before splits
  netAmount   Float     // after platform fees
  currency    String    @default("USD")
  streams     Int?
  downloads   Int?
  status      String    @default("pending") // pending | distributed | paid
  paidAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([trackId, period])
  @@index([source])
}

model Showcase {
  id          Int       @id @default(autoincrement())
  name        String    // e.g. "Rise Up Showcase — Spring 2026"
  venue       String    // "Ground Zero Blues Club" | "B.B. King's" | "Blues Room" | etc
  venueCity   String    // "Clarksdale" | "Memphis" | "Natchez"
  venueState  String    @default("MS")
  date        DateTime
  time        String?   // "7:00 PM CT"
  description String?   @db.Text
  capacity    Int?
  ticketPrice String?   // "$15" | "Free" | "$10-25"
  ticketUrl   String?
  status      String    @default("planning") // planning | confirmed | promoted | completed | cancelled
  eventId     Int?      // Link to Event model if also listed as an event
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  slots       ShowcaseSlot[]

  @@index([date, status])
  @@index([venue])
}

model ShowcaseSlot {
  id          Int       @id @default(autoincrement())
  showcaseId  Int
  showcase    Showcase  @relation(fields: [showcaseId], references: [id], onDelete: Cascade)
  artistId    Int
  artist      Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  setOrder    Int       @default(0)  // Performance order
  setLength   Int?      // Minutes
  status      String    @default("confirmed") // invited | confirmed | declined | performed
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([showcaseId, artistId])
  @@index([artistId])
}

model TourStop {
  id          Int       @id @default(autoincrement())
  artistId    Int
  artist      Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  venue       String
  venueCity   String
  venueState  String    @default("MS")
  date        DateTime
  time        String?
  guarantee   Int?      // Artist guarantee in cents
  doorDeal    String?   // "70/30" | "80/20" | "flat $500"
  ticketPrice String?
  status      String    @default("hold") // hold | confirmed | advanced | completed | cancelled
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([artistId, date])
  @@index([date, status])
  @@index([venue])
}

// ─── Snap & Share Photo System ───────────────────────────────
model PhotoSession {
  id          String   @id @default(cuid())
  code        String   @unique // short code for QR URL e.g. "blues-room-mar-15"
  name        String   // "Blues Room — March 15, 2026"
  location    String   // "The Big Muddy Inn"
  date        DateTime
  description String?
  coverImage  String?  // GCS URL
  status      String   @default("active") // active | archived
  photos      Photo[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Photo {
