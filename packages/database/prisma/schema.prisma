  corridorCityId    Int?                           // FK to CorridorCity
  corridorCity      CorridorCity? @relation(fields: [corridorCityId], references: [id])

  // ── Back-references from Touring models ──
  touringVenues     TouringVenue[]
  touringHotels     TouringHotel[]
  touringRestaurants TouringRestaurant[]

