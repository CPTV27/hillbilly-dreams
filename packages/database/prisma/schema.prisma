// packages/database/prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Use connection pooling URL for serverless (Next.js API routes, Firebase Functions)
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// MAGAZINE
// ─────────────────────────────────────────────────────────────

model Article {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  category    String    // city-guide | feature | photo-essay | interview | food-drink | music
  city        String?   // memphis | clarksdale | natchez | new-orleans | vicksburg | etc.
  author      String    @default("Big Muddy Magazine")
  status      String    @default("draft")     // draft | review | published
  excerpt     String?
  body        String?   @db.Text
  heroImage   String?   // Cloudflare R2 URL
  readTime    String?   // e.g. "6 min read"
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // ── S2PX Bridge Provenance ──
  sourceSystem    String?   // "s2px" | null (manual)
  sourceProjectId String?   // S2PX UPID e.g. "S2P-042-2025"
  sourcePayload   String?   @db.Text  // Sanitized JSON audit trail
  sourceSyncedAt  DateTime?

  @@index([status, publishedAt])
  @@index([category])
  @@index([city])
  @@index([sourceSystem, sourceProjectId])
}

// ─────────────────────────────────────────────────────────────
// RADIO
// ─────────────────────────────────────────────────────────────

model Playlist {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  trackCount  Int      @default(0)
  spotifyUrl  String?  // spotify:playlist:xxx or https://open.spotify.com/playlist/xxx
  coverImage  String?  // Cloudflare R2 URL
  status      String   @default("active")  // active | archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model Event {
  id          Int      @id @default(autoincrement())
  name        String
  date        DateTime
  time        String?              // e.g. "7:00 PM CT" — stored separately for display flexibility
  artist      String?
  description String?
  price       String?              // e.g. "$25" or "Free" — string to allow flexibility
  capacity    Int      @default(50)
  status      String   @default("upcoming")  // upcoming | sold-out | cancelled | completed
  stream      Boolean  @default(false)       // whether this event will be livestreamed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date, status])
}

// ─────────────────────────────────────────────────────────────
// NEWSLETTER
// ─────────────────────────────────────────────────────────────

model NewsletterIssue {
  id          Int      @id @default(autoincrement())
  issueNumber Int      @unique
  subject     String
  storyTitle  String?
  storyBody   String?  @db.Text
  playlist    String?  // Playlist name or Spotify URL
  reason      String?  // "Why You Should Go" section
  quickHits   String?  @db.Text  // Comma-separated or JSON array of bullets
  status      String   @default("draft")  // draft | scheduled | sent
  sendDate    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, sendDate])
}

// ─────────────────────────────────────────────────────────────
// CRM / CONTACTS
// ─────────────────────────────────────────────────────────────

model Contact {
  id           Int       @id @default(autoincrement())
  name         String
  role         String?
  organization String?
  email        String?
  phone        String?
  category     String?   // artist | vendor | media | partner | guest | team
  notes        String?   @db.Text
  lastContact  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([category])
  @@index([email])
}

// ─────────────────────────────────────────────────────────────
// DASHBOARD METRICS
// ─────────────────────────────────────────────────────────────

model Metric {
  id        Int      @id @default(autoincrement())
  key       String   @unique  // e.g. "newsletter_subscribers", "inn_occupancy_rate", "spotify_followers"
  value     Float
  target    Float?
  label     String?           // Display label: "Newsletter Subscribers"
  unit      String?           // "subscribers", "%", "followers", etc.
  source    String?           // "beehiiv" | "cloudbeds" | "spotify" | "manual"
  updatedAt DateTime @updatedAt

  @@index([key])
}

// ─────────────────────────────────────────────────────────────
// BRIDGE CLIENTS (Multi-Tenant Content-as-a-Service)
// ─────────────────────────────────────────────────────────────

model BridgeClient {
  id          Int      @id @default(autoincrement())
  name        String                    // "Scan2Plan", "FutureClient_X"
  apiKey      String   @unique          // Public identifier (cuid)
  apiSecret   String                    // HMAC-SHA256 secret (64-char hex, hashed at rest)
  status      String   @default("active") // active | suspended
  allowedCategories String[]            // Which article categories this client can create
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastSyncAt  DateTime?

  @@index([apiKey])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// SOCIAL MEDIA
// ─────────────────────────────────────────────────────────────

model SocialAccount {
  id          Int      @id @default(autoincrement())
  platform    String   // twitter | tiktok | instagram | threads | bluesky | linkedin
  handle      String   // @outsiderecon, @bigmuddymedia, etc.
  brand       String   @default("bigmuddy") // bigmuddy | radio | magazine | touring | economics
  status      String   @default("active")   // active | paused | disconnected
  notes       String?
  clientId    Int?
  client      Client?  @relation(fields: [clientId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       SocialPost[]

  @@unique([platform, handle])
  @@index([brand])
  @@index([status])
}

model SocialPost {
  id          Int       @id @default(autoincrement())
  accountId   Int
  account     SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  content     String    @db.Text           // Post body / caption
  mediaUrls   String[]                     // GCS image/video URLs
  postUrl     String?                      // URL after publishing (paste back)
  status      String    @default("draft")  // draft | ready | published | failed
  scheduledAt DateTime?                    // When to publish (null = no schedule)
  publishedAt DateTime?                    // When actually published
  sourceType  String?                      // article | newsletter | event | economics | manual
  sourceId    String?                      // Reference to source content ID
  tags        String[]                     // hashtags, topics
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([accountId, status])
  @@index([status, scheduledAt])
  @@index([sourceType, sourceId])
}

// ─────────────────────────────────────────────────────────────
// CLIENT MANAGEMENT (Media-as-a-Service)
// ─────────────────────────────────────────────────────────────

model Client {
  id               Int       @id @default(autoincrement())
  name             String
  slug             String    @unique
  tier             String    @default("front-porch") // front-porch | route | river-room | blues-room
  businessType     String    // restaurant | venue | hotel | shop | tour | service | other
  city             String
  state            String    @default("MS")
  address          String?
  phone            String?
  email            String?
  website          String?
  description      String?   @db.Text
  voiceProfile     Json?     // AI-generated brand voice document
  platforms        String[]  // which social platforms they're on
  gbpPlaceId       String?   // Google Business Profile place ID
  gbpUrl           String?   // Google Maps URL
  stripeCustomerId String?
  logoUrl          String?
  heroImageUrl     String?
  contactName      String?   // Primary contact person
  contactEmail     String?
  contactPhone     String?
  notes            String?   @db.Text
  status           String    @default("onboarding") // onboarding | active | paused | churned
  onboardedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts         SocialAccount[]
  reviews          Review[]
  calendars        ContentCalendar[]
  reports          Report[]
  invoices         Invoice[]

  @@index([city])
  @@index([tier, status])
  @@index([status])
}

model Review {
  id             Int       @id @default(autoincrement())
  clientId       Int
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform       String    // google | yelp | tripadvisor | facebook
  externalId     String    @unique
  author         String
  rating         Int       // 1-5
  text           String?   @db.Text
  response       String?   @db.Text   // Our drafted response
  responseStatus String    @default("pending") // pending | drafted | approved | posted | skipped
  aiDraft        String?   @db.Text   // AI-generated response draft
  postedAt       DateTime  // When the review was posted
  respondedAt    DateTime? // When we responded
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([clientId, platform])
  @@index([responseStatus])
  @@index([clientId, postedAt])
}

model ContentCalendar {
  id          Int       @id @default(autoincrement())
  clientId    Int
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month       Int       // 1-12
  year        Int
  posts       Json      // Array of planned post objects with content, platform, scheduledDate, status
  status      String    @default("draft") // draft | review | approved | active | completed
  generatedAt DateTime  @default(now())
  approvedAt  DateTime?
  approvedBy  String?
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([clientId, month, year])
  @@index([status])
}

model Report {
  id          Int       @id @default(autoincrement())
  clientId    Int
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month       Int
  year        Int
  data        Json      // Metrics snapshot: posts published, engagement, reviews, etc.
  summary     String?   @db.Text // AI-generated narrative summary
  pdfUrl      String?   // GCS URL for generated PDF
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([clientId, month, year])
}

model Invoice {
  id               Int       @id @default(autoincrement())
  clientId         Int
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  stripeInvoiceId  String?   @unique
  amount           Int       // Amount in cents
  currency         String    @default("usd")
  status           String    @default("draft") // draft | open | paid | void | uncollectible
  periodStart      DateTime
  periodEnd        DateTime
  paidAt           DateTime?
  dueDate          DateTime?
  pdfUrl           String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([clientId, status])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// PUBLISHING PIPELINE
// ─────────────────────────────────────────────────────────────

model PublishJob {
  id          Int       @id @default(autoincrement())
  postId      Int       // Reference to SocialPost
  platform    String    // twitter | instagram | tiktok | bluesky | linkedin | facebook | gbp
  status      String    @default("pending") // pending | processing | published | failed | cancelled
  externalId  String?   // Platform's post ID after publishing
  externalUrl String?   // URL of published post
  error       String?   @db.Text
  attempts    Int       @default(0)
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, scheduledAt])
  @@index([postId])
}

// ─────────────────────────────────────────────────────────────
// AUTH (NextAuth.js)
// ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("viewer")  // admin | ops | artist | viewer
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// INN OPERATIONS (Launch Tracker + Delta Dawn)
// ============================================================

model LaunchTask {
  id           Int       @id @default(autoincrement())
  taskNumber   Int       @unique
  title        String
  session      Int       // 1-7 (work session grouping)
  sessionName  String    // e.g. "Quick Wins", "Google Business Profile"
  platform     String?   // e.g. "Google", "Facebook", "Yelp"
  timeEstimate String?   // e.g. "15 min", "1 hour"
  status       String    @default("pending") // pending, done, skipped
  assignedTo   String?   // "tracy", "amy", "chase"
  guide        String?   @db.Text // HTML step-by-step instructions
  link         String?   // external URL for the task
  requiresLogin Boolean  @default(false)
  contentPackSlug String? // FK reference to ContentPack.slug
  triggers     Json?     // array of trigger objects
  notes        Json?     @default("[]") // array of note objects
  completedAt  DateTime?
  completedBy  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  contentPack  ContentPack? @relation(fields: [contentPackSlug], references: [slug])
}

model ContentPack {
  slug     String @id // e.g. "google_description", "facebook_about"
  title    String
  sections Json   // array of { label: string, content: string }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks    LaunchTask[]
}

model OpsActivity {
  id        Int      @id @default(autoincrement())
  type      String   // "login", "task_completed", "task_skipped", "chat", "content_viewed"
  message   String
  userId    String?  // email
  userName  String?
  taskId    Int?     // optional reference to task number
  createdAt DateTime @default(now())
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  sessionId String
  role      String   // "user" or "assistant"
  content   String   @db.Text
  userId    String   // email of the user
  userName  String
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([userId])
}

