{
  "name": "big-muddy-media",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "tsx apps/web/server.ts",
    "dev:turbo": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "test": "npx playwright test --project=local",
    "test:smoke": "npx playwright test e2e/smoke.spec.ts --project=local",
    "test:p0": "npx playwright test e2e/p0-journeys.spec.ts --project=local",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate": "turbo run db:migrate",
    "postinstall": "pnpm --filter @bigmuddy/database exec prisma generate",
    "sync-docs": "node scripts/sync-docs.mjs",
    "media:synology-indexer": "tsx scripts/media/synology-indexer.ts",
    "scout:leads": "tsx scripts/scouts/lead-generator.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "overrides": {
      "serialize-javascript": ">=7.0.3"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.2",
    "checkly": "^7.7.0",
    "chokidar": "^4.0.0",
    "fast-xml-parser": "^4.3.6",
    "jiti": "^2.6.1",
    "tsx": "^4.19.0"
  }
}
